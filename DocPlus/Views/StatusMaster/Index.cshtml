@using System.Reflection
@inject IStringLocalizerFactory LocalizerFactory

@{
    var Localizer = LocalizerFactory.Create("SharedResource", Assembly.GetExecutingAssembly().GetName().Name);
    ViewData["Title"] = @Localizer["Status_Master"];
}
<style>
    .modal-dialog {
        max-width: 600px !important;
    }

    #tblStatus th:nth-child(2),
    #tblStatus th:nth-child(3),
    #tblStatus td:nth-child(2),
    #tblStatus td:nth-child(3) {
        text-align: center !important;
        white-space: nowrap;
        width: 1%; /* 👈 important: extra space remove */
    }


    #tblStatus td:nth-child(3) {
        padding-right: 5px !important; /* 👈  spacing */
    }

    #tblStatus td:nth-child(2) {
        padding-right: 8px !important;
    }
</style>


<!-- Subheader -->
<div class="kt-subheader kt-grid__item" id="kt_subheader">

    <div class="kt-subheader__main">

        <div class="kt-subheader__breadcrumbs">

            <a asp-controller="Dashboard" asp-action="Index" class="kt-subheader__breadcrumbs-home">
                <i class="flaticon2-shelter"></i>
            </a>

            <span class="kt-subheader__breadcrumbs-separator"></span>

            <a href="javascript:;" class="kt-subheader__breadcrumbs-link">
                @Localizer["Basic_Settings"]
            </a>

            <span class="kt-subheader__breadcrumbs-separator"></span>

            <a asp-controller="StatusMaster" asp-action="Index" class="kt-subheader__breadcrumbs-link">
                @Localizer["Status_Master"]
            </a>

        </div>
    </div>
    <!-- RIGHT SIDE → Buttons -->
    <div class="kt-subheader__toolbar d-flex">

        <button ="javascript:;" id="btnAddStatus"
                class="btn btn-brand btn-elevate btn-icon-sm mr-2"
                onclick="StatusMaster.SetForAdd();" title="@Localizer["Add_Status"]">
            <i class="fas fa-plus-circle"></i> @Localizer["Add_Status"]
        </button>

        <div id="divExport">
            <button type="button"
                    class="btn btn-default btn-icon-sm"
                    onclick="StatusMaster.Export();" title="@Localizer["Export"]">
                <i class="la la-download"></i> Export
            </button>
        </div>

    </div>

</div>
<!-- Main Grid -->
<div class="kt-portlet kt-portlet--mobile">

    <div class="kt-portlet__body table-responsive" id="divIDViewStatus" style="display:none;">
        <!--begin: Datatable -->
        <table class="table table-striped table-hover table-checkable" id="tblStatus">

            <thead>
                <tr>
                    <th> @Localizer["Status"]</th>
                    <th style="text-align:center;"> @Localizer["Edit"]</th>
                    <th style="text-align:center;"> @Localizer["Delete"]</th>
                </tr>
            </thead>
            <tbody></tbody>

        </table>
    </div>

</div>
<!-- Add Status Modal -->
<div class="modal fade" id="StatusModal">

    <div class="modal-dialog modal-dialog-centered">

        <div class="modal-content">

            <div class="modal-header">

                <h5 class="modal-title">@Localizer["Add_Status"]</h5>

                <button type="button" class="close"
                        data-dismiss="modal"
                        onclick="StatusMaster.SetForClose();" title="@Localizer["Close"]"></button>

            </div>

            <div class="modal-body">

                <form id="frmStatus">

                    <input type="text"
                           id="txtStatus"
                           class="form-control"
                           title="@Localizer["Enter_Status"]"
                           placeholder="@Localizer["Enter_Status"]" />

                </form>

            </div>

            <div class="modal-footer">

                <button class="btn btn-success" title="  @Localizer["Save"]"
                        onclick="StatusMaster.AddUpdate();">
                    @Localizer["Save"]
                </button>

                <button type="button"
                        class="btn btn-warning" title="@Localizer["Reset"]"
                        onclick="StatusMaster.ResetData();">
                    @Localizer["Reset"]
                </button>

                <button class="btn btn-danger" title="  @Localizer["Close"]"
                        onclick="StatusMaster.SetForClose();">
                    @Localizer["Close"]
                </button>

            </div>

        </div>

    </div>

</div>
<form id="__AjaxAntiForgeryForm">
    @Html.AntiForgeryToken()
</form>
<input type="hidden" id="hdnStatusID" value="0" />
<script id="Grid_Data_Template_tblStatus" type="text/x-jquery-tmpl">
    <tr>
        <td>${statuS_NAME}</td>

        <!-- Edit -->
        <td>
            <i class="fa fa-edit text-primary action-icon "
               onclick="StatusMaster.Edit(${statuS_ID})" title="Edit" style="cursor:pointer;"></i>
        </td>

        <!-- Delete -->
        <td>
            <i class="fa fa-trash text-danger action-icon"
               onclick="StatusMaster.Delete(${statuS_ID},'${statuS_NAME}')" title="Delete" style="cursor:pointer;"></i>
        </td>
    </tr>
</script>
<script src="~/scripts/StatusMaster.js"></script>


