@{
    ViewData["Title"] = "Status Master";
}

<style>
    .modal-dialog {
        max-width: 600px !important;
    }
</style>

<!-- Subheader -->

<div class="kt-subheader kt-grid__item" id="kt_subheader">

    <div class="kt-subheader__main">

        <div class="kt-subheader__breadcrumbs">

            <a asp-controller="Dashboard" asp-action="Index" class="kt-subheader__breadcrumbs-home">
                <i class="flaticon2-shelter"></i>
            </a>

            <span class="kt-subheader__breadcrumbs-separator"></span>

            <a href="javascript:;" class="kt-subheader__breadcrumbs-link">
                Basic Settings
            </a>

            <span class="kt-subheader__breadcrumbs-separator"></span>

            <a asp-controller="StatusMaster" asp-action="Index" class="kt-subheader__breadcrumbs-link">
                Status Master
            </a>

        </div>

    </div>


</div>

<!-- Main Grid -->

<div class="kt-portlet kt-portlet--mobile">

    <div class="kt-portlet__head kt-portlet__head--lg">

        <div class="kt-portlet__head-label">

            <span class="kt-portlet__head-icon">
                <i class="kt-font-brand fas fa-check-square"></i>
            </span>

            <h3 class="kt-portlet__head-title">
                Status Master
            </h3>

        </div>


        <div class="kt-portlet__head-toolbar">

            <div class="kt-portlet__head-wrapper">

                <div class="kt-portlet__head-actions">

                    <!-- Export -->
                    <button type="button"
                            class="btn btn-default btn-icon-sm"
                            onclick="ExportToExcelGrid('#tblStatus','excel')">

                        <i class="la la-download"></i>
                        Export

                    </button>

                    &nbsp;

                    <!-- Add -->
                    <a href="javascript:;"
                       class="btn btn-brand btn-elevate btn-icon-sm"
                       onclick="showAddModal()">

                        <i class="fas fa-plus-circle"></i>

                        Add Status

                    </a>

                </div>

            </div>

        </div>

    </div>



    <div class="kt-portlet__body table-responsive">

        <table class="table table-striped table-hover table-checkable" id="tblStatus">

            <thead>
                <tr>
                    <th>Status</th>
                    <th style="width:120px;">Action</th>
                </tr>
            </thead>

            <tbody>

                <tr>
                    <td>Active</td>
                    <td>
                        <a href="#" class="btn btn-sm btn-clean btn-icon btn-icon-md btnDelete">
                            <i class="fas fa-trash-alt text-danger"></i>
                        </a>
                    </td>
                </tr>

                <tr>
                    <td>Inactive</td>
                    <td>
                        <a href="#" class="btn btn-sm btn-clean btn-icon btn-icon-md btnDelete">
                            <i class="fas fa-trash-alt text-danger"></i>
                        </a>
                    </td>
                </tr>

                <tr>
                    <td>Pending</td>
                    <td>
                        <a href="#" class="btn btn-sm btn-clean btn-icon btn-icon-md btnDelete">
                            <i class="fas fa-trash-alt text-danger"></i>
                        </a>
                    </td>
                </tr>

            </tbody>

        </table>

    </div>


</div>

<!-- Add Status Modal -->

<div class="modal fade" id="AddStatusModal">

    <div class="modal-dialog modal-dialog-centered">

        <div class="modal-content">

            <div class="modal-header">

                <h5 class="modal-title">Add Status</h5>

                <button type="button" class="close" data-dismiss="modal"></button>

            </div>

            <div class="modal-body">

                <input type="text"
                       id="txtStatus"
                       class="form-control"
                       placeholder="Enter Status" />

            </div>

            <div class="modal-footer">

                <button class="btn btn-primary" onclick="saveStatus()">Save</button>

                <button class="btn btn-danger" onclick="resetStatus()">Reset</button>

                <button class="btn btn-secondary" data-dismiss="modal">Close</button>

            </div>

        </div>

    </div>
 

</div>

@section Scripts {

    <script>

        $(document).ready(function () {

            $('#tblStatus').DataTable({
                pageLength:10,
                ordering:false
            });

        });


        function showAddModal()
        {
            $("#txtStatus").val("");
            $("#AddStatusModal").modal("show");
        }


        function saveStatus()
        {

            var status = $("#txtStatus").val().trim();

            if(status=="")
            {
                alert("Enter Status");
                return;
            }

            $('#tblStatus').DataTable().row.add([
                status,
                "<a href='#' class='btn btn-sm btn-clean btn-icon btn-icon-md btnDelete'><i class='fas fa-trash-alt text-danger'></i></a>"
            ]).draw();

            $("#AddStatusModal").modal("hide");

        }


        function resetStatus()
        {
            $("#txtStatus").val("");
        }


        $(document).on("click",".btnDelete",function(){

            $('#tblStatus').DataTable().row($(this).parents('tr')).remove().draw();

        });


        function ExportToExcelGrid(tableId,type)
        {
            alert("Export Called for " + tableId);
        }

    </script>

}
