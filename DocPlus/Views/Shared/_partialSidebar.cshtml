<script type="text/javascript">
        $(function () {
        if ($('li[menuname="' + $(location).attr('href').split('/')[3] + '"]').hasClass("kt-menu__item--active"))
                $('li[menuname="' + $(location).attr('href').split('/')[3] + '"]').closest('li.MainMenu').addClass("kt-menu__item--open");

            if ($(location).attr('href').split('/')[3] == 'BuildingDetails') {
                $('li[menuname="MeterReading"]').addClass("kt-menu__item--active");
            }

            if ($(location).attr('href').split('/')[3] == 'MeterApproval') {
                $('li[menuname="MeterApproval"]').addClass("kt-menu__item--active");
            }

            if ($(location).attr('href').split('/')[3] == 'UnitofMeasurement') {
                $('li[menuname="UOM"]').addClass("kt-menu__item--active");
                $('li[menuname="UOM"]').closest('li.MainMenu').addClass("kt-menu__item--open");
            }

            if ($(location).attr('href').split('/')[3] == 'MeterDetails') {
                $('li[menuname="MeterReading"]').addClass("kt-menu__item--active");
            }
            //if ($(location).attr('href').split('/')[3] == 'Analytics') {
            //    $('.Analytics').addClass("kt-menu__item--active");
            //}
            if ($(location).attr('href').split('/')[3] == 'UsageAndDollerReport') {
                $('.UsageAndDollerReport').addClass("kt-menu__item--active");
            }

            //if ($(location).attr('href').split('/')[3] == 'UsageAndEmissionReport') {
            //    $('.UsageAndEmissionReport').addClass("kt-menu__item--active");
            //}
    });
        var userScreenInfo = null, userScreenActionInfo = null;

        $(document).ready(function () {
            userScreenInfo = '@Html.Raw(globalScreenAuth)';/*used in common js*/
            userScreenActionInfo = '@Html.Raw(globalScreenActionAuth)';/*used in common js*/
            SetScreenInfo(userScreenInfo);
            ScreenActionInfo(userScreenActionInfo);
            /*Screen search*/
            MenuScreenSearch();
        });
        var CurrentScreenID = '@ViewBag.screenID'
        var CurrentEncryptScreenID = '@ViewBag.EncryptScreenID'
        var globalScreenID = {
            Dashboard: $("#hf_GlobalDashboardScreenID").val(),
            Clinical: $("#hf_Clinical").val(),
            DoctorMaster: $("#hf_DoctorMaster").val(),
            User: $("#hf_User").val(),
            StatusMaster: $("#hf_StatusMaster").val(),
            ProfessionMaster: $("#hf_ProfessionMaster").val(),
            CategoryMaster: $("#hf_CategoryMaster").val(),
            ICD10Master: $("#hf_ICD10Master").val(),
            DSM4Master: $("#hf_DSM4Master").val(),
            OccupationMaster: $("#hf_OccupationMaster").val(),
            Appointments: $("#hf_Appointments").val(),
            PatientRegistrations: $("#hf_PatientRegistrations").val(),
            Payments: $("#hf_Payments").val(),
            Billing: $("#hf_Billing").val(),
            PatientReports: $("#hf_PatientReports").val(),
            FinancialReports: $("#hf_FinancialReports").val(),
            AppointmentReports: $("#hf_AppointmentReports").val()
    };
</script>
