@using DocPlus.Entities.ViewModels;
@using Microsoft.Extensions.Caching.Memory;
@using Newtonsoft.Json;
@using System.Collections;
@using Microsoft.AspNetCore.Http;
@using DocPlus.Utilities;

@inject IMemoryCache Cache;

@{
    Hashtable? User_LoginInfo = null;
    List<MenuScreen_VM>? objMenuList = null;
    List<ScreenAction_VM>? objActionList = null;

    string globalScreenAuth = "";
    string globalScreenActionAuth = "";

    var sessionData = Context.Session.GetString("UserData");

    if (string.IsNullOrEmpty(sessionData))
    {
        Context.Response.Redirect("/Login");
    }
    else
    {
        User_LoginInfo = JsonConvert.DeserializeObject<Hashtable>(sessionData);

        if (User_LoginInfo != null)
        {
            string? UserRoleID = User_LoginInfo["UserRoleID"]?.ToString();

            string objectMenuKey = "objMenu" + UserRoleID;
            string objectActionKey = "objAction" + UserRoleID;

            if (Cache.TryGetValue(objectMenuKey, out List<MenuScreen_VM>? menuList))
            {
                objMenuList = menuList;
                globalScreenAuth = JsonConvert.SerializeObject(menuList);
            }

            if (Cache.TryGetValue(objectActionKey, out List<ScreenAction_VM>? actionList))
            {
                objActionList = actionList;
                globalScreenActionAuth = JsonConvert.SerializeObject(actionList);
            }
        }
        else
        {
            Context.Response.Redirect("/Login");
        }
    }
}

