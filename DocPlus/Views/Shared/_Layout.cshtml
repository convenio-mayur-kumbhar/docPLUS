@using Newtonsoft.Json;
@using System.Collections;
@using Microsoft.AspNetCore.Http;

@{
    string UserName = "";
    string UserID = "";
    string CustomerName = "";
    string CustomerId = "";
    string IsCustomerUser = "";

    if (Context.Session.GetString("UserData") == null)
    {
        Context.Response.Redirect("/Login/Index");  // ✅ FIXED URL
    }
    else
    {
        Hashtable User_LoginInfo = JsonConvert.DeserializeObject<Hashtable>
       (Context.Session.GetString("UserData"));
        UserName = User_LoginInfo["UserName"].ToString();
        UserID = User_LoginInfo["UserID"].ToString();
        //  CustomerId = User_LoginInfo["CustomerID"].ToString();
        CustomerName = User_LoginInfo["CustomerName"].ToString();
        IsCustomerUser = User_LoginInfo["IsCustomerUser"].ToString();
    }
}
