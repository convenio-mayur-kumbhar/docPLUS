         function CustomerPopup() {
               // alert("Hi");
                Reload_ddl_Global(null, "#globalCustomerSearch", "/AjaxCommon/GetCustomerDDL", null, "Select", function () {
                $("#globalCustomerSearch").val(@CustomerId).select2();
                 $("#SwitchCustomer").modal();
               // alert("Hi123");
               // var myModal123 = new bootstrap.Modal(document.getElementById('SwitchCustomer'));
               //  myModal123.show();
                });


         }

         function goScreen(name, id) {

            if (IsNotNull(id)) {
                GetAjaxData("/Login/UserCustomer", { CustomerName: name, CustomerId: id, UserName: _UserName }, function (data) {
                    var Result = data.data;
                   // window.location.href = '/'+ Result.actionName + '/Index/'+ Result.actionCode ;
                    $("#lbl_CustomerName").text(name);
                    window.location.reload()
                }, function () { });

                _CustomerID = id;
                _CustomerName = name;

            }
            else
               LogOff();
        }



         if ('@IsCustomerUser' == "True")
            $("#CustomerDetail").hide();

    </script>

