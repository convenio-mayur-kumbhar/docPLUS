        @@media (min-width: 1025px) {
            .kt-header--fixed.kt-subheader--fixed.kt-subheader--enabled .kt-wrapper {
                padding-top: 65px !important;
            }
        }

        @@media (max-width: 1024px) {
            .kt-header-mobile {
                background-color: #A3BAC3 !important;
            }
        }

        div.loadercontainer.modal-backdrop {
            background-color: transparent;
        }

        /* Custom Loder create eith ecg + StatusScope */
        .med-loader {
            position: fixed;
            width: 100%;
            height: 100%;
            top: 0;
            left: 0;
            z-index: 99999;
            display: flex;
            justify-content: center;
            align-items: center;
            /* 🔥 MAGIC */
            backdrop-filter: blur(6px);
            background: rgba(255, 255, 255, 0.4);
        }
        /* Container */
        .med-container {
            text-align: center;
        }

        /* ECG LINE */
        .ecg {
            width: 220px;
            height: 80px;
            stroke: #36a3f7;
            stroke-width: 2;
            fill: none;
            stroke-dasharray: 400;
            stroke-dashoffset: 400;
            animation: ecgAnim 2s linear infinite;
        }

        @@keyframes ecgAnim {
            to {
                stroke-dashoffset: 0;
            }
        }

        /* Stethoscope pulse */
        .stetho {
            font-size: 42px;
            margin-top: 10px;
            animation: pulse 1.2s infinite;
        }

        @@keyframes pulse {
            0%, 100% {
                transform: scale(1);
            }

            50% {
                transform: scale(1.25);
            }
        }

        /* Text */
        .med-text h4 {
            color: #5d78ff;
            margin-top: 10px;
        }

        .med-text p {
            margin: 3px;
            color: #555;
            font-size: 14px;
        }
    </style>

