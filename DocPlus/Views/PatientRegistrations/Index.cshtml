@{
    ViewData["Title"] = "Patient Registrations";
}
<div class="kt-subheader__main">

    <h3 class="kt-subheader__title">
        Patient Management
    </h3>

    <span class="kt-subheader__separator kt-hidden"></span>

    <div class="kt-subheader__breadcrumbs">

        <a asp-controller="Dashboard"
           asp-action="Index"
           class="kt-subheader__breadcrumbs-home">
            <i class="flaticon2-shelter"></i>
        </a>

        <span class="kt-subheader__breadcrumbs-separator"></span>

        <a href="javascript:;"
           class="kt-subheader__breadcrumbs-link">
            Patient Management
        </a>

        <span class="kt-subheader__breadcrumbs-separator"></span>

        <a asp-controller="PatientRegistrations"
           asp-action="Index"
           class="kt-subheader__breadcrumbs-link">
            Patient Registrations
        </a>

    </div>

</div>
<div class="form-group row">

    <div class="col-md-3">

        <label>First Name</label>

        <input type="text"
               id="txtFirstNameSearch"
               class="form-control" />

    </div>

    <div class="col-md-3">

        <label>Mobile</label>

        <input type="text"
               id="txtMobileSearch"
               class="form-control" />

    </div>

    <div class="col-md-3">

        <label>Email</label>

        <input type="text"
               id="txtEmailSearch"
               class="form-control" />

    </div>

    <div class="col-md-3">

        <label>Status</label>

        <select id="ddlStatusSearch"
                class="form-control">

            <option value="">All</option>
            <option>Active</option>
            <option>Inactive</option>

        </select>

    </div>

</div>




<div class="kt-portlet__head kt-portlet__head--lg">

    <div class="kt-portlet__head-label">

        <h3 class="kt-portlet__head-title">
            Patient List
        </h3>

    </div>

    <div class="kt-portlet__head-toolbar">

        <div class="kt-portlet__head-actions">

            <input type="button"
                   class="btn btn-primary"
                   value="Search"
                   onclick="PatientRegistration.Search();" />

            <button type="button"
                    class="btn btn-danger"
                    onclick="PatientRegistration.Reset();">

                Reset

            </button>

            <span>

                <a href="javascript:;"
                   class="btn btn-brand btn-elevate btn-icon-sm"
                   onclick="PatientRegistration.OpenAddModal();">

                    <i class="fas fa-plus-circle"></i>
                    Add Patient

                </a>

            </span>

        </div>

    </div>

</div>



<div class="kt-portlet__body table-responsive">

    <table class="table table-striped table-hover table-checkable"
           id="tblPatient">

        <thead>

            <tr>

                <th>First Name</th>
                <th>Last Name</th>
                <th>Mobile</th>
                <th>Email</th>
                <th>Gender</th>
                <th>Status</th>
                <th>Edit</th>
                <th>Delete</th>

            </tr>

        </thead>

        <tbody></tbody>

    </table>

</div>




<div class="modal-dialog modal-dialog-centered">

    <div class="modal-content">

        <div class="modal-header">

            <h5 class="modal-title">
                Add Patient
            </h5>

            <button type="button"
                    class="close"
                    data-dismiss="modal">
            </button>

        </div>


        <div class="modal-body">

            <form id="frmPatient">

                <div class="row">

                    <div class="col-md-4">

                        <div class="form-group">

                            <label>First Name</label>

                            <input type="text"
                                   id="txtFirstName"
                                   class="form-control" />

                        </div>

                    </div>

                    <div class="col-md-4">

                        <div class="form-group">

                            <label>Last Name</label>

                            <input type="text"
                                   id="txtLastName"
                                   class="form-control" />

                        </div>

                    </div>

                    <div class="col-md-4">

                        <div class="form-group">

                            <label>Mobile</label>

                            <input type="text"
                                   id="txtMobile"
                                   class="form-control" />

                        </div>

                    </div>

                </div>



                <div class="row">

                    <div class="col-md-4">

                        <div class="form-group">

                            <label>Email</label>

                            <input type="text"
                                   id="txtEmail"
                                   class="form-control" />

                        </div>

                    </div>

                    <div class="col-md-4">

                        <div class="form-group">

                            <label>Gender</label>

                            <select id="ddlGender"
                                    class="form-control">

                                <option>Male</option>
                                <option>Female</option>

                            </select>

                        </div>

                    </div>

                    <div class="col-md-4">

                        <div class="form-group">

                            <label>Status</label>

                            <select id="ddlStatus"
                                    class="form-control">

                                <option>Active</option>
                                <option>Inactive</option>

                            </select>

                        </div>

                    </div>

                </div>

            </form>

        </div>



        <div class="modal-footer">

            <button type="button"
                    class="btn btn-primary"
                    onclick="PatientRegistration.Save();">

                Save

            </button>

            <button type="button"
                    class="btn btn-danger"
                    onclick="PatientRegistration.ResetForm();">

                Reset

            </button>

            <button type="button"
                    class="btn btn-secondary"
                    data-dismiss="modal">

                Close

            </button>

        </div>

    </div>

</div>

@section Scripts {

    <script src="~/js/PatientRegistration.js"></script>

}