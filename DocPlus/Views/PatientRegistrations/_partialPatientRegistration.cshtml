@using System.Reflection
@inject IStringLocalizerFactory LocalizerFactory

@{
    var Localizer = LocalizerFactory.Create("SharedResource", Assembly.GetExecutingAssembly().GetName().Name);
}

<style>
    body,
    .page-content,
    .form-control,
    .table,
    .btn,
    label,
    select,
    input {
        font-size: 13px !important;
        font-family: 'Open Sans','Segoe UI',Arial !important;
    }

    .card-panel {
        background: #fff;
        border: 1px solid #dcdcdc;
        border-radius: 6px;
        padding: 20px;
        margin-top: 10px;
        box-shadow: 0 2px 6px rgba(0,0,0,0.05);
    }

    .tabs-left {
        border: 1px solid #e5e5e5;
    }

        .tabs-left li {
            float: none;
        }

            .tabs-left li a {
                display: block;
                padding: 6px 8px;
                color: #333 !important;
                border-bottom: 1px solid #e5e5e5;
            }

            .tabs-left li:last-child a {
                border-bottom: none;
            }

</style>
<link href="https://cdnjs.cloudflare.com/ajax/libs/jqueryui/1.14.1/themes/base/jquery-ui.min.css" rel="stylesheet" />

@* <div class="kt-subheader kt-grid__item" id="kt_subheader">
    <div class="kt-subheader__main">
        <span class="kt-subheader__separator kt-hidden"></span>
        <div class="kt-subheader__breadcrumbs">
            <a asp-controller="Dashboard" asp-action="Index" class="kt-subheader__breadcrumbs-home"><i class="flaticon2-shelter"></i></a>
            <span class="kt-subheader__breadcrumbs-separator"></span>
            <a href="javascript:;" class="kt-subheader__breadcrumbs-link">
                Admin Settings
            </a>
            <a href="@Url.Action("Index","PatientRegistrations")"
               class="kt-subheader__breadcrumbs-link cursor-pointer">
                @Localizer["Patient Registrations"]
            </a>
        </div>
    </div>
    <div class="kt-subheader__toolbar">
        <div class="kt-subheader__wrapper">
        </div>
    </div>
</div><!-- SUBHEADER --> *@

<div class="kt-portlet kt-portlet--mobile p-2 mb-1 mt-3">
    <form id="frm_PatientAdd">
        <div style="display:flex; justify-content:space-between; align-items:center; margin:10px 5px;">

            <!-- LEFT SIDE: Patient Details -->
            <div style="font-weight:600; font-size:16px;">
                <strong>@Localizer["Add_Patient"]:</strong>
            </div>

            <!-- RIGHT SIDE: Close Button -->
            <div>
                <i id="btnClose" class="fa fa-times"
                   style="cursor:pointer;font-size:18px; color: #555555; "
                   onclick="patientRegistration.SetForClose();">
                </i>
            </div>

        </div>


        <div class="card card-custom gutter-b" style="margin-bottom:.5rem;">
            <div class="card-header card-header-tabs-line">
                <div class="card-toolbar">
                    <ul class="nav nav-light-success nav-bold nav-pills" style="margin: 0 !important;">

                        <li class="nav-item" style="flex:1; text-align:center;">
                            <a class="nav-link active" data-toggle="tab" href="#general">
                                @Localizer["General_Information"]
                            </a>
                        </li>

                        <li class="nav-item" style="flex:1; text-align:center;background:#f9f9f9;">
                            <a class="nav-link" data-toggle="tab" href="#nextOfKin">
                                @Localizer["Next_of_Kin"]
                            </a>
                        </li>

                        <li class="nav-item" style="flex:1; text-align:center;background:#f9f9f9;">
                            <a class="nav-link" data-toggle="tab" href="#otherProfessionals">
                                @Localizer["Other_Professionals"]
                            </a>
                        </li>

                    </ul>
                </div>
            </div>
        </div>


        <div class="tab-content mt-3">
            <!-- GENERAL FORM -->
            <div id="general" class="tab-pane fade show active col-md-12" style="border:1px solid #ddd;padding:20px;background:#f9f9f9;">
                <form id="frmGeneral">
                    <div class="row">
                        <div> <input type="hidden" id="patientID" /> </div>
                        <div class="col-md-4">
                            <label>@Localizer["First_Name"]</label><asterisk></asterisk>
                            <input type="text" class="form-control" id="txtFirstName" value="@ViewBag.FirstName" />
                        </div>

                        <div class="col-md-4">
                            <label>@Localizer["Middle_Name"]</label>
                            <input type="text" class="form-control" id="txtMiddleName" />
                        </div>

                        <div class="col-md-4">
                            <label>@Localizer["Last_Name"]</label><asterisk></asterisk>
                            <input type="text" class="form-control" id="txtLastName" value="@ViewBag.LastName" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-4">
                            <label>@Localizer["DOB"]</label><asterisk></asterisk>
                            <input type="date" class="form-control" id="txtDOB" value="@ViewBag.DOB" />
                        </div>
                        <div class="col-md-4">
                            <label>@Localizer["Marital_Status"]</label>
                            <select class="form-control" id="ddlMaritalStatus">
                                <option value="">Select</option>
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label>@Localizer["Occupation"]</label>
                            <select class="form-control" id="ddlOccupation">
                                <option>Select</option>
                            </select>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-4">
                            <label>@Localizer["Telephone_No"]</label>
                            <input type="text" class="form-control" id="txtTeleNo" />
                        </div>

                        <div class="col-md-4">
                            <label>@Localizer["Mobile_No"]</label><asterisk></asterisk>
                            <input type="text" class="form-control" id="txtMobileNo" value="@ViewBag.Mobile" />
                        </div>

                        <div class="col-md-4">
                            <label>@Localizer["Email"]</label>
                            <input type="text" class="form-control" id="txtEmail" value="@ViewBag.Email" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-4">
                            <label>@Localizer["Category"]</label>
                            <select class="form-control" id="ddlCategory">
                                <option>Select</option>
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label>@Localizer["Status"]</label>
                            <select class="form-control" id="ddlStatus">
                                <option>Select</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label>@Localizer["Gender"]</label><asterisk></asterisk>
                            <div style="margin-top:6px;" id="radioGender">
                                <label class="radio-inline">
                                    <input type="radio" name="Gender" value="M"> @Localizer["Male"]
                                </label>
                                <label class="radio-inline mx-1">
                                    <input type="radio" name="Gender" value="F"> @Localizer["Female"]
                                </label>
                                <label class="radio-inline mx-1">
                                    <input type="radio" name="Gender" value="O"> @Localizer["Other"]
                                </label>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <label>@Localizer["Address"]</label>
                            <input type="text" class="form-control" id="txtAddress" />
                        </div>

                        <div class="col-md-6">
                            <label>@Localizer["Referred_By"]</label>
                            <input type="text" class="form-control" id="txtReferredBy" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-12">
                            <label>@Localizer["Remarks"]</label>
                            <textarea class="form-control small-box" id="txtRemarks"></textarea>
                        </div>
                    </div>

                    <button type="button" class="btn btn-primary mt-3" id="txtSave" onclick="patientRegistration.SaveGeneralInfo();">@Localizer["Save"]</button>
                    <button type="button" class="btn btn-danger mt-3 mx-2" onclick="patientRegistration.ResetForm();">@Localizer["Reset"]</button>
                </form>
            </div>

            <!-- NEXT OF KIN FORM -->
            <div id="nextOfKin" class="tab-pane fade" style="border:1px solid #ddd;padding:12px;background:#f9f9f9;">
                <form id="frmKin">
                    <div style="border:1px solid #ddd;padding:12px;background:#f9f9f9;">
                        <div> <input type="hidden" id="NOK_ID" /> </div>
                        @* <div> <input type="hidden" id="patientID" /> </div> *@
                        <div class="row">
                            <div class="col-md-6">
                                <label>@Localizer["Name"]</label><asterisk></asterisk>
                                <input type="text" class="form-control" id="kinName">
                            </div>

                            <div class="col-md-6">
                                <label>@Localizer["Relation"]</label><asterisk></asterisk>
                                <input type="text" class="form-control" id="kinRelation">
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-4">
                                <label>@Localizer["Telephone_No"]</label>
                                <input type="text" class="form-control" id="kinTeleNo">
                            </div>

                            <div class="col-md-4">
                                <label>@Localizer["Mobile_No"]</label><asterisk></asterisk>
                                <input type="text" class="form-control" id="kinMobileNo">
                            </div>

                            <div class="col-md-4">
                                <label>@Localizer["Email"]</label>
                                <input type="text" class="form-control" id="kinEmail">
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <label>@Localizer["Address"]</label><asterisk></asterisk>
                                <textarea class="form-control" id="kinAddress"></textarea>
                            </div>

                            <div class="col-md-6">
                                <label>@Localizer["Remarks"]</label>
                                <textarea class="form-control" id="kinRemarks"></textarea>
                            </div>
                        </div>

                        <!-- ADD BUTTON -->

                        <button id="btnAddKin" type="button" class="btn btn-success btn-xs" style="margin-top:8px;" onclick="patientRegistration.AddKin();">
                            <i class="fa fa-plus"></i> @Localizer["Add"]
                        </button>

                    </div>
                </form>
                <!-- TABLE SECTION -->
                @* <div style="overflow-x:auto;margin-top:12px;">  *@
                @*      <table id="tblKin" class="table table-bordered table-condensed" style="width:100%;">  *@

                @*          <thead style="background:#f9f9f9;">  *@
                @*              <tr > *@

                <div class="kt-portlet__body table-responsive">
                    <table class="table table-striped table-hover table-checkable" id="tblKin">
                        <thead>
                            <tr>
                                <th>@Localizer["Name"]</th>
                                <th>@Localizer["Relation"]</th>
                                <th>@Localizer["Address"]</th>
                                <th>@Localizer["Telephone_No"]</th>
                                <th>@Localizer["Mobile_No"]</th>
                                <th>@Localizer["Email"]</th>
                                <th>@Localizer["Remarks"]</th>
                                <th width="80">@Localizer["Edit"]</th>
                                <th width="80">@Localizer["Delete"]</th>
                            </tr>
                        </thead>

                        <tbody id="tblKinBody"></tbody>

                    </table>
                    <script id="Grid_Data_Template_tblKin" type="text/x-jquery-tmpl">
                        <tr data-id="${nok_ID}">
                        <td>${noK_NAME}</td>
                        <td>${noK_RELATION}</td>
                        <td>${noK_ADDR}</td>
                        <td>${noK_TELENO}</td>
                        <td>${noK_MOBNO}</td>
                        <td>${noK_EMAIL}</td>
                        <td>${noK_REMARKS}</td>

                            <td class="Edit">
                                <a href="javascript:;" class="btn btn-sm btn-clean btn-icon btn-icon-md" title="Edit" onclick="patientRegistration.SetNOKUpdate('${noK_ID}','${noK_NAME}', '${noK_RELATION}', '${noK_ADDR}','${noK_TELENO}', '${noK_MOBNO}',' ${noK_EMAIL}', '${noK_REMARKS}');">
                                    <i class="far fa-edit"></i>
                                </a>
                            </td>
                            <td class="Delete">
                                <a href="javascript:;" class="btn btn-sm btn-clean btn-icon btn-icon-md" title="Delete" onclick="patientRegistration.DeleteNOK('${noK_ID}','${noK_NAME}')">
                                    <i class="fas fa-trash-alt text-red"></i>
                                </a>
                            </td>
                        </tr>
                    </script>
                </div>
            </div>

            <!-- OTHER PROFESSIONALS FORM -->
            <div id="otherProfessionals" class="tab-pane fade" style="border:1px solid #ddd;padding:12px;background:#f9f9f9;">
                <form id="frmProfessional">
                    <div style="border:1px solid #ddd;padding:12px;background:#f9f9f9;">

                        <div class="row">
                            <div> <input type="hidden" id="hdnopId" /> </div>
                            <div class="col-md-4">
                                <label>@Localizer["Name"]</label><asterisk></asterisk>
                                <input type="text" class="form-control" id="otherProfName" />
                            </div>

                            <div class="col-md-4">
                                <label>@Localizer["Profession"]</label><asterisk></asterisk>
                                <select class="form-control" id="ddlProfession">
                                    <option>Select</option>
                                </select>
                            </div>

                            <div class="col-md-4">
                                <label>@Localizer["Email"]</label><asterisk></asterisk>
                                <input type="email" class="form-control" id="otherProfEmailID" />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-4">
                                <label>@Localizer["Telephone_No"]</label>
                                <input type="text" class="form-control" id="otherProfTeleNo" />
                            </div>

                            <div class="col-md-4">
                                <label>@Localizer["Mobile_No"]</label><asterisk></asterisk>
                                <input type="text" class="form-control" id="otherProfMobileNo" />
                            </div>

                            <div class="col-md-4">
                                <label>@Localizer["Remarks"]</label>
                                <textarea class="form-control" id="otherProfRemarks"></textarea>
                            </div>

                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <label>@Localizer["Address"]</label><asterisk></asterisk>
                                <textarea class="form-control" id="otherProfAddress"></textarea>
                            </div>

                        </div>

                        <!-- BUTTON -->
                        <button id="btnAddProf" type="button" class="btn btn-success btn-xs" style="margin-top:8px;" onclick="patientRegistration.AddOtherProf();">
                            <i class="fa fa-plus"></i> @Localizer["Add"]
                        </button>

                    </div>
                </form>
                <div class="kt-portlet__body table-responsive">
                    <table class="table table-striped table-hover table-checkable" id="tblOtherProf">
                        <thead>
                            <tr>
                                <th>@Localizer["Name"]</th>
                                <th>@Localizer["Profession"]</th>
                                <th>@Localizer["Telephone_No"]</th>
                                <th>@Localizer["Mobile_No"]</th>
                                <th>@Localizer["Email"]</th>
                                <th>@Localizer["Address"]</th>
                                <th>@Localizer["Remarks"]</th>
                                <th width="80">@Localizer["Edit"]</th>
                                <th width="80">@Localizer["Delete"]</th>
                            </tr>
                        </thead>

                        <tbody id="tblOPBody"></tbody>

                    </table>
                    <script id="Grid_Data_Template_tblOtherProf" type="text/x-jquery-tmpl">
                        <tr data-id="${oP_ID}" >
                            <td>${oP_NAME}</td>
                            <td>${professioN_NAME}</td>
                            <td>${oP_TELENO}</td>
                            <td>${oP_MOBNO}</td>
                            <td>${oP_EMAIL}</td>
                            <td>${oP_ADDR}</td>
                            <td>${oP_REMARKS}</td>

                            <td class="Edit">
                                <a href="javascript:;" class="btn btn-sm btn-clean btn-icon btn-icon-md" title="Edit" onclick="patientRegistration.UpdateOP('${oP_ID}','${oP_NAME}','${professioN_ID}','${oP_TELENO}','${oP_MOBNO}','${oP_EMAIL}','${oP_ADDR}','${oP_REMARKS}')">
                                    <i class="far fa-edit"></i>
                                </a>
                            </td>
                            <td class="Delete">
                                <a href="javascript:;" class="btn btn-sm btn-clean btn-icon btn-icon-md" title="Delete" onclick="patientRegistration.DeleteOP('${oP_ID}','${oP_NAME}')">
                                    <i class="fas fa-trash-alt text-red"></i>
                                </a>
                            </td>
                        </tr>
                    </script>
                </div>

            </div>

        </div>

        @* <div class="modal-footer">
                @* <button class="btn btn-primary" onclick="patientRegistration.Save();">@Localizer["Save"]</button> 

                <button class="btn btn-secondary" data-dismiss="modal" onclick="patientRegistration.SetForClose();">@Localizer["Close"]</button>
            </div> *@


    </form>
</div>

@section Scripts {
    <script src="~/assets/js/jquery.dataTables.min.js"></script>
    <script src="~/assets/js/dataTables.bootstrap.min.js"></script>
    <script src="~/scripts/patientregistrations.js"></script>
}


