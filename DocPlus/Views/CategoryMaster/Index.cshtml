@using System.Reflection
@inject IStringLocalizerFactory LocalizerFactory

@{
    var Localizer = LocalizerFactory.Create("SharedResource", Assembly.GetExecutingAssembly().GetName().Name);
    ViewData["Title"] = @Localizer["Category_Master"];
}


<style>
    .modal-dialog {
        max-width: 600px !important;
    }

    #tblCategory th:nth-child(2),
    #tblCategory th:nth-child(3),
    #tblCategory td:nth-child(2),
    #tblCategory td:nth-child(3) {
        text-align: center !important;
        white-space: nowrap;
        width: 1%; /* 👈 important: extra space remove */
    }


    #tblCategory td:nth-child(3) {
        padding-right: 5px !important; /* 👈  spacing */
    }

    #tblCategory td:nth-child(2) {
        padding-right: 8px !important;
    }
   
</style>

<!-- Subheader -->

<div class="kt-subheader kt-grid__item" id="kt_subheader">

    <div class="kt-subheader__main">

        <div class="kt-subheader__breadcrumbs">

            <a asp-controller="Dashboard" asp-action="Index" class="kt-subheader__breadcrumbs-home">
                <i class="flaticon2-shelter"></i>
            </a>

            <span class="kt-subheader__breadcrumbs-separator"></span>

            <a href="javascript:;" class="kt-subheader__breadcrumbs-link">
                @Localizer["Basic_Settings"]
            </a>

            <span class="kt-subheader__breadcrumbs-separator"></span>

            <a asp-controller="CategoryMaster" asp-action="Index" class="kt-subheader__breadcrumbs-link">
                @Localizer["Category_Master"]
            </a>

        </div>
    </div>
    <!-- RIGHT SIDE → Buttons -->
    <div class="kt-subheader__toolbar d-flex">

        <button href="javascript:;" id="btnAddCategory"
           class="btn btn-brand btn-elevate btn-icon-sm mr-2"
           onclick="category.SetForAdd();" title="@Localizer["Add_Category"]">
            <i class="fas fa-plus-circle"></i> @Localizer["Add_Category"]
        </button>

        <div id="divExport">
            <button type="button"
                    class="btn btn-default btn-icon-sm"
                    onclick="category.Export();" title="@Localizer["Export"]">
                <i class="la la-download"></i> Export
            </button>
        </div>

    </div>

</div>

<div class="kt-portlet kt-portlet--mobile">

    <div class="kt-portlet__body table-responsive" id="divIDViewCategory" style="display:none;">
        <!--begin: Datatable -->
        <table class="table table-striped table-hover table-checkable" id="tblCategory">

            <thead>
                <tr>
                    <th> @Localizer["Category"]</th>
                    <th style="text-align:center;"> @Localizer["Edit"]</th>
                    <th style="text-align:center;"> @Localizer["Delete"]</th>
                </tr>
            </thead>

            <tbody></tbody>

        </table>
    </div>

</div>


<!-- Add Category Modal -->

<div class="modal fade" id="CategoryModal">

    <div class="modal-dialog modal-dialog-centered">

        <div class="modal-content">

            <div class="modal-header">

                <h5 class="modal-title" title="@Localizer["Add_Category"]">@Localizer["Add_Category"]</h5>

                <button type="button" class="close"
                        data-dismiss="modal"
                        onclick="category.SetForClose();" title="@Localizer["Close"]"></button>

            </div>

            <div class="modal-body">

                <form id="frmCategory">

                    <input type="text"
                           id="txtCategory"
                           class="form-control"
                           placeholder="@Localizer["Enter_Category"]" />

                </form>

            </div>

            <div class="modal-footer">

                <button class="btn btn-success"
                        onclick="category.AddUpdate();" title="@Localizer["Save"]">
                    @Localizer["Save"]
                </button>

                <button type="button"
                        class="btn btn-warning"
                        onclick="category.ResetData();" title="@Localizer["Reset"]">
                    @Localizer["Reset"]
                </button>

                <button class="btn btn-danger"
                        onclick="category.SetForClose();" title="@Localizer["Close"]">
                    @Localizer["Close"]
                </button>

            </div>

        </div>

    </div>

</div>
<form id="__AjaxAntiForgeryForm">
    @Html.AntiForgeryToken()
</form>
<input type="hidden" id="hdnCategoryID" value="0" />
<script id="Grid_Data_Template_tblCategory" type="text/x-jquery-tmpl">
    <tr>
        <td>${categorY_NAME}</td>

        <!-- Edit -->
        <td>
            <i class="fa fa-edit text-primary action-icon"
               onclick="category.Edit(${categorY_ID})" title="@Localizer["Edit"]" style="cursor:pointer"></i>
        </td>

        <!-- Delete -->
        <td>
            <i class="fa fa-trash text-danger action-icon"
               onclick="category.Delete(${categorY_ID},'${categorY_NAME}')" title="@Localizer["Delete"]" style="cursor:pointer"></i>
        </td>
    </tr>
</script>
<script src="~/scripts/CategoryMaster.js"></script>

