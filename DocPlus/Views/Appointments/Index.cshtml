@using System.Reflection
@inject IStringLocalizerFactory LocalizerFactory

@{
    var Localizer = LocalizerFactory.Create("SharedResource", Assembly.GetExecutingAssembly().GetName().Name);
    ViewData["Title"] = @Localizer["Appointments"];
}

<style>
    body,
    .page-content,
    .form-control,
    .table,
    .btn,
    label,
    select,
    input,
    textarea {
        font-size: 13px !important;
        font-family: 'Open Sans','Segoe UI',Arial !important;
    }

    .card-panel {
        background: #fff;
        border: 1px solid #dcdcdc;
        border-radius: 6px;
        padding: 20px;
        margin-top: 10px;
        box-shadow: 0 2px 6px rgba(0,0,0,0.05);
    }

    .section-header {
        background: #3b6ea5;
        color: #fff;
        padding: 8px 15px;
        font-size: 16px;
        font-weight: 600;
        border-radius: 4px 4px 0 0;
        margin: -20px -20px 20px -20px;
    }

    /* Modal Width */
    .modal-xl {
        max-width: 900px;
    }



    /* Title */
    .appointment-modal .modal-title {
        font-weight: 600;
        font-size: 18px;
    }

    /* Body spacing */
    .appointment-modal .modal-body {
        padding: 25px;
    }

    /* Labels */
    .appointment-modal label {
        font-weight: 600;
        font-size: 13px;
        margin-bottom: 5px;
    }

    /* Inputs */
    .appointment-modal .form-control {
        height: 38px;
        font-size: 13px;
    }

    /* Textarea */
    .appointment-modal textarea {
        height: auto;
    }
    /* Fix select2 inside modal */
    .appointment-modal .select2-container {
        width: 100% !important;
    }



    /* Buttons */
    .modal-footer .btn {
        min-width: 90px;
    }

</style>

<!-- SUBHEADER -->
<div class="kt-subheader kt-grid__item d-flex justify-content-between align-items-center">

    <!-- LEFT SIDE → Breadcrumb -->
    <div class="kt-subheader__main">
        <div class="kt-subheader__breadcrumbs">
            <a asp-controller="Dashboard" asp-action="Index" class="kt-subheader__breadcrumbs-home">
                <i class="flaticon2-shelter"></i>
            </a>
            <span class="kt-subheader__breadcrumbs-separator"></span>
            <a href="javascript:;" class="kt-subheader__breadcrumbs-link">
                @Localizer["Admin_Settings"]
            </a>
            <span class="kt-subheader__breadcrumbs-separator"></span>
            <a asp-controller="Appointment" asp-action="Index" class="kt-subheader__breadcrumbs-link">
                @Localizer["Appointments"]
            </a>
        </div>
    </div>

    <!-- RIGHT SIDE → Buttons -->
    <div class="kt-subheader__toolbar d-flex">

        <a href="javascript:;" id="btnAddAppointment"
           class="btn btn-brand btn-elevate btn-icon-sm mr-2"
           onclick="appointments.SetForAdd();">
            <i class="fas fa-plus-circle"></i> @Localizer["Add_Appointment"]
        </a>

        <div id="divExport" style="display:none;">
            <button type="button"
                    class="btn btn-default btn-icon-sm"
                    onclick="appointments.Export();">
                <i class="la la-download"></i> @Localizer["Export"]
            </button>
        </div>

    </div>

</div>

<div class="kt-portlet kt-portlet--mobile p-3 mb-2">

    <div class="form-group row align-items-end">

        <div class="col-md-3">
            <label>@Localizer["Patient_Name"]:</label>
            <input type="text"
                   id="txtPatientName"
                   class="form-control"
                   placeholder="Enter Patient Name">
        </div>

        <div class="col-xs-12 col-md-3 col-lg-3">
            <label>@Localizer["Date"]:</label>
            <div class="input-daterange input-group">
                <input type="date" class="form-control" id="textSearchDate" />
            </div>
        </div>
        <div class="col-md-6">
            <button type="button" class="btn btn-success"
                    onclick="appointments.SetForSearch()">
                @Localizer["Search"]
            </button>
            <button type="button" class="btn btn-danger"
                    onclick="appointments.ResetSearch();">
                @Localizer["Reset"]
            </button>

        </div>

    </div>

    <!-- Dynamic Search Results -->
    <div id="appointmentResults" class="mt-3">
        <!-- Appointments will be rendered here -->
    </div>

</div>
<!-- GRID -->
<div class="kt-portlet kt-portlet--mobile">

    <div class="kt-portlet__body table-responsive" id="divIDViewAppointments" style="display:none;">
        <!--begin: Datatable -->
        <table class="table table-striped table-hover table-checkable" id="tblAppointment">

            <template>
                @Localizer["Appointment_List"]

            </template>

            <thead>
                <tr>
                    <th>@Localizer["Patient_Name"]</th>
                    <th>@Localizer["Date"]</th>
                    <th>@Localizer["Time"]</th>
                    <th>@Localizer["Tele_No"]</th>
                    <th>@Localizer["Mobile_No"]</th>
                    <th>@Localizer["Comments"]</th>
                    <th>@Localizer["Edit"]</th>
                    <th>@Localizer["Delete"]</th>
                </tr>
            </thead>

            <tbody></tbody>

        </table>
    </div>
</div>

<!-- MODAL -->

<div class="modal fade" id="AppointmentModal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-xl modal-dialog-centered" role="document">
        <div class="modal-content appointment-modal">

            <!-- HEADER -->
            <div class="modal-header">
                <h5 class="modal-title">@Localizer["Appointment_Details"]</h5>
                <button type="button" class="close" data-dismiss="modal" onclick="appointments.SetForClose();"></button>
            </div>

            <!-- BODY -->
            <div class="modal-body">
                <form id="frmAppointment">
                    <!-- ✅ Hidden Fields -->
                    <input type="hidden" id="APPT_ID" />
                    <input type="hidden" id="PAT_ID" />
                    <div class="row">

                        <div class="col-md-6 form-group">
                            <label>@Localizer["Patient_Name"]<span class="text-danger">*</span></label>
                            <select id="ddlPatientDropdown" class="form-control">
                                <option value="">--Select--</option>
                            </select>
                        </div>

                        <div class="col-md-3 form-group">
                            <label>@Localizer["Date"]<span class="text-danger">*</span></label>
                            <input type="date" id="txtDate" class="form-control" placeholder="@Localizer["Select_Date"]">


                        </div>

                        <div class="col-md-3 form-group">
                            <label>@Localizer["Time"]<span class="text-danger">*</span></label>
                            <input type="time" id="txtTime" class="form-control">
                        </div>

                    </div>

                    <div class="row">

                        <div class="col-md-3 form-group">
                            <label>@Localizer["Tele_No"]</label>
                            <input type="text" id="txtTele" class="form-control" readonly placeholder="@Localizer["Enter_Telephone_no"]">
                        </div>

                        <div class="col-md-3 form-group">
                            <label>@Localizer["Mobile_No"]</label>
                            <input type="text" id="txtCell" class="form-control" readonly placeholder="@Localizer["Enter_Mobile_No"]">
                        </div>

                        <div class="col-md-6 form-group">
                            <label>@Localizer["Comments"] <span class="text-danger">*</span></label>
                            <textarea id="txtComments" class="form-control" rows="2" style="height:65px;" placeholder="@Localizer["Enter_Comments"]"></textarea>
                        </div>

                    </div>

                </form>
            </div>

            <!-- FOOTER -->
            <div class="modal-footer">

                <button class="btn btn-success" onclick="appointments.AddUpdate();" title="@Localizer["Save"]">@Localizer["Save"]</button>
                <button type="button" class="btn btn-warning" onclick="appointments.ResetData();" title="@Localizer["Reset"]">@Localizer["Reset"]</button>
                <button class="btn btn-danger" onclick="appointments.SetForClose();" title="@Localizer["Close"]">@Localizer["Close"]</button>
                <div id="divExport" style="display:none">
                    <button class="btn btn-secondary" onclick="appointments.Export();" title="@Localizer["Export"]"><i class="la la-download"></i> @Localizer["Export"]</button>
                </div>
            </div>
            </div>
    </div>
</div>
<input type="hidden" id="hdnAppointmentID" value="0" />
<form id="__AjaxAntiForgeryForm">
    @Html.AntiForgeryToken()
</form>
<script id="Grid_Data_Template_tblAppointment" type="text/x-jquery-tmpl">
    <tr>
        <td>${paT_FULLNAME}</td>
        <td>${appT_DATECustom}</td>
        <td>${appT_TIMECustom}</td>
        <td>${paT_TELENO}</td>
        <td>${paT_MOBNO}</td>
        <td>${appT_COMMENTS}</td>
        <td>
            <button class="btn btn-sm btn-primary"
                    onclick="appointments.Edit(${appT_ID})">
                Edit
            </button>
        </td>
        <td>
            <button class="btn btn-sm btn-danger"
                    onclick="appointments.Delete(${appT_ID})">
                Delete
            </button>
        </td>
    </tr>
</script>
<script src="~/scripts/appointments.js"></script>

