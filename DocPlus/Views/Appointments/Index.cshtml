<div class="kt-portlet kt-portlet--mobile p-3 mb-2">

    <div class="form-group row align-items-end">

        <div class="col-md-3">
            <label>Patient Name</label>
            <input type="text"
                   id="txtPatientName"
                   class="form-control"
                   placeholder="Enter Patient Name">
        </div>

        <div class="col-md-3">
            <label>Date:</label>
            <div class="input-daterange input-group">
                <input type="text" id="txtvalidFrom" class="form-control date-picker" name="startMonth" placeholder="Date" autocomplete="off" />
            </div>
        </div>

        <div class="col-md-6">
            <button class="btn btn-primary mr-2"
                    onclick="appointmentMaster.Search();">
                Search
            </button>

            <button class="btn btn-danger mr-2"
                    onclick="appointmentMaster.Reset();">
                Reset
            </button>

            <button class="btn btn-secondary"
                    onclick="appointmentMaster.Export();">
                <i class="la la-download"></i> Export
            </button>
        </div>

    </div>

    <!-- Dynamic Search Results -->
    <div id="appointmentResults" class="mt-3">
        <!-- Appointments will be rendered here -->
    </div>

</div>
<!-- GRID -->
<div class="kt-portlet kt-portlet--mobile">
    <div class="kt-portlet__head kt-portlet__head--lg">
        <div class="kt-portlet__head-label">
            <h3 class="kt-portlet__head-title">Appointment List</h3>
        </div>
        <div class="kt-portlet__head-toolbar">
            <a href="javascript:;" class="btn btn-brand btn-elevate btn-icon-sm" onclick="appointmentMaster.OpenAdd();">
                <i class="fas fa-plus-circle"></i> Add Appointment
            </a>
        </div>
    </div>

    <div class="kt-portlet__body table-responsive">
        <table class="table table-striped table-hover table-checkable" id="tblAppointment">
            <thead>
                <tr>
                    <th>Patient</th>
                    <th>Date</th>
                    <th>Time</th>
                    <th>Tele</th>
                    <th>Cell</th>
                    <th>Comments</th>
                    <th>Edit</th>
                    <th>Delete</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

<!-- MODAL -->

<div class="modal fade" id="AppointmentModal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-xl modal-dialog-centered" role="document">
        <div class="modal-content appointment-modal">

            <!-- HEADER -->
            <div class="modal-header">
                <h5 class="modal-title">Appointment Details</h5>
                <button type="button" class="close" data-dismiss="modal"></button>
            </div>

            <!-- BODY -->
            <div class="modal-body">
                <form id="frmAppointment">

                    <div class="row">

                        <div class="col-md-6 form-group">
                            <label>Patient Name</label>
                            <input type="text" id="txtPatient" class="form-control" placeholder="Enter Patient Name">
                        </div>

                        <div class="col-md-3 form-group">
                            <label>Date</label>
                            <input type="text" id="txtvalidFrom" class="form-control date-picker" placeholder="Select Date" autocomplete="off">
                        </div>

                        <div class="col-md-3 form-group">
                            <label>Time</label>
                            <input type="time" id="txtTime" class="form-control">
                        </div>

                    </div>

                    <div class="row">

                        <div class="col-md-3 form-group">
                            <label>Telephone</label>
                            <input type="text" id="txtTele" class="form-control" placeholder="Telephone">
                        </div>

                        <div class="col-md-3 form-group">
                            <label>Mobile</label>
                            <input type="text" id="txtCell" class="form-control" placeholder="Mobile Number">
                        </div>

                        <div class="col-md-6 form-group">
                            <label>Comments</label>
                            <textarea id="txtComment" class="form-control" rows="2" placeholder="Add comments"></textarea>
                        </div>

                    </div>

                </form>
            </div>

            <!-- FOOTER -->
            <div class="modal-footer">
                <button class="btn btn-success" onclick="appointmentMaster.Save();">
                    Save
                </button>

                <button class="btn btn-warning" onclick="appointmentMaster.ResetForm();">
                    Reset
                </button>

                <button class="btn btn-secondary" data-dismiss="modal">
                    Close
                </button>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script src="~/assets/js/jquery.dataTables.min.js"></script>
    <script src="~/assets/js/dataTables.bootstrap.min.js"></script>

    <script>
        var appointmentMaster = {
            data: [],
            table: null,

            Init: function () {
                this.table = $("#tblAppointment").DataTable({
                    pageLength: 10,
                    ordering: true
                });
            },

            OpenAdd: function () {
                $("#AppointmentModal").modal("show");
            },

            Save: function () {
                var appt = {
                    patient: $("#txtPatient").val(),
                    date: $("#txtDate").val(),
                    time: $("#txtTime").val(),
                    tele: $("#txtTele").val(),
                    cell: $("#txtCell").val(),
                    comment: $("#txtComment").val()
                };

                if (!appt.patient) {
                    alert("Enter patient name");
                    return;
                }

                this.data.push(appt);
                this.Load();
                this.ResetForm();
                $("#AppointmentModal").modal("hide");
            },

            Load: function () {
                this.table.clear();
                this.data.forEach(function (x, i) {
                    appointmentMaster.table.row.add([
                        x.patient,
                        x.date,
                        x.time,
                        x.tele,
                        x.cell,
                        x.comment,
                        "<i class='fa fa-edit' onclick='appointmentMaster.Edit(" + i + ")'></i>",
                        "<i class='fa fa-trash text-danger' onclick='appointmentMaster.Delete(" + i + ")'></i>"
                    ]);
                });
                this.table.draw();
            },

            Edit: function (i) {
                var appt = this.data[i];
                $("#txtPatient").val(appt.patient);
                $("#txtDate").val(appt.date);
                $("#txtTime").val(appt.time);
                $("#txtTele").val(appt.tele);
                $("#txtCell").val(appt.cell);
                $("#txtComment").val(appt.comment);

                this.data.splice(i, 1);
                this.OpenAdd();
            },

            Delete: function (i) {
                if (confirm("Delete appointment?")) {
                    this.data.splice(i, 1);
                    this.Load();
                }
            },

            Search: function () {
                var patient = $("#txtPatientName").val();
                var date = $("#txtDateSearch").val();

                this.table.column(0).search(patient);
                this.table.column(1).search(date);
                this.table.draw();
            },

            Reset: function () {
                $("#txtPatientName").val("");
                $("#txtDateSearch").val("");
                this.table.search("").columns().search("").draw();
            },

            Export: function () {
                alert("Export logic here");
            },

            ResetForm: function () {
                $("#frmAppointment")[0].reset();
            }
        };
            //// DATE PICKER
        if ($(".date-picker").length > 0) {
            $('.date-picker').datepicker({
                autoclose: true,
                todayHighlight: true,
                format: DateTimeDataFormat.ddMyyyy
            });

            $(".date-picker").datepicker("setDate", new Date());
        }
        $(document).ready(function () {
            appointmentMaster.Init();
        });
    </script>
}