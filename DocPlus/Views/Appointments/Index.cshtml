<link href="~/assets/css/dataTables.bootstrap.min.css" rel="stylesheet" />

<style>
    body,
    .page-content,
    .form-control,
    .table,
    .btn,
    label,
    select,
    input,
    textarea {
        font-size: 13px !important;
        font-family: 'Open Sans','Segoe UI',Arial !important;
    }

    .card-panel {
        background: #fff;
        border: 1px solid #dcdcdc;
        border-radius: 6px;
        padding: 20px;
        margin-top: 10px;
        box-shadow: 0 2px 6px rgba(0,0,0,0.05);
    }

    .section-header {
        background: #3b6ea5;
        color: #fff;
        padding: 8px 15px;
        font-size: 16px;
        font-weight: 600;
        border-radius: 4px 4px 0 0;
        margin: -20px -20px 20px -20px;
    }

    /* Modal Width */
    .modal-xl {
        max-width: 900px;
    }

  

    /* Title */
    .appointment-modal .modal-title {
        font-weight: 600;
        font-size: 18px;
    }

    /* Body spacing */
    .appointment-modal .modal-body {
        padding: 25px;
    }

    /* Labels */
    .appointment-modal label {
        font-weight: 600;
        font-size: 13px;
        margin-bottom: 5px;
    }

    /* Inputs */
    .appointment-modal .form-control {
        height: 38px;
        font-size: 13px;
    }

    /* Textarea */
    .appointment-modal textarea {
        height: auto;
    }

    /* Footer */
   

    /* Buttons */
    .modal-footer .btn {
        min-width: 90px;
    }

</style>

