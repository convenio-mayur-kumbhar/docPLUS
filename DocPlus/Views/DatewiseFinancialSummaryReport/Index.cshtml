@section Scripts {

    <script src="~/assets/js/jquery.dataTables.min.js"></script>
    <script src="~/assets/js/dataTables.bootstrap.min.js"></script>
    <script src="~/assets/js/bootstrap-datepicker.min.js"></script>


    <script>

        var FinancialReport={

        BindData:function(){

        var from=$("#txtFromDate").val();
        var to=$("#txtToDate").val();

        if(from=="" || to==""){

        alert("Select From and To Date");
        return;

        }


        var data=[

        {
        PatientCode:"P001",
        PatientName:"Rahul Sharma",
        ApptCode:"A101",
        ApptDateTime:"12-Mar-2026 10:30 AM",
        TotalAmt:"1500",
        PaidAmt:"1000",
        BalanceAmt:"500",
        PaidDate:"12-Mar-2026",
        PaymentDetails:"Cash"
        },

        {
        PatientCode:"P002",
        PatientName:"Sneha Patil",
        ApptCode:"A102",
        ApptDateTime:"12-Mar-2026 11:00 AM",
        TotalAmt:"2000",
        PaidAmt:"2000",
        BalanceAmt:"0",
        PaidDate:"12-Mar-2026",
        PaymentDetails:"Card"
        }

        ];


        var tbody=$("#tblFinancialReport tbody");

        tbody.empty();


        $.each(data,function(i,item){

        var row="<tr>"+

        "<td>"+item.PatientCode+"</td>"+
        "<td>"+item.PatientName+"</td>"+
        "<td>"+item.ApptCode+"</td>"+
        "<td>"+item.ApptDateTime+"</td>"+
        "<td>"+item.TotalAmt+"</td>"+
        "<td>"+item.PaidAmt+"</td>"+
        "<td>"+item.BalanceAmt+"</td>"+
        "<td>"+item.PaidDate+"</td>"+
        "<td>"+item.PaymentDetails+"</td>"+

        "</tr>";

        tbody.append(row);

        });


        $("#tblFinancialReport").DataTable({

        destroy:true,
        pageLength:10,
        searching:true,
        paging:true,
        info:true,
        ordering:true

        });

        },



        ResetData:function(){

        $("#txtFromDate").val("");
        $("#txtToDate").val("");

        $("#tblFinancialReport tbody").empty();

        },



        ExportExcel:function(){

        var table=document.getElementById("tblFinancialReport");

        var html=table.outerHTML;

        var url='data:application/vnd.ms-excel,'+escape(html);

        var link=document.createElement("a");

        link.href=url;

        link.download="FinancialSummaryReport.xls";

        link.click();

        }

        };



        $(document).ready(function(){

        $('.date-picker').datepicker({

        autoclose:true,
        todayHighlight:true,
        format:"dd-M-yyyy"

        });

        });

    </script>

}