                    </button>

                    <button type="button"
                            class="btn btn-secondary"
                            onclick="FinancialReport.ResetData();">

                        Reset

                    </button>

                    <button type="button"
                            class="btn btn-default btn-icon-sm"
                            onclick="FinancialReport.ExportExcel();">

                        <i class="la la-download"></i>
                        Export

                    </button>

                </div>

            </div>



            <!-- TABLE -->

            <div class="kt-portlet__body table-responsive tableFixHead"
                 id="divFinancialGrid">

                <table id="tblFinancialReport"
                       class="table table-striped table-bordered table-hover">

                    <thead>

                        <tr>

                            <th>Patient Code</th>
                            <th>Patient Name</th>
                            <th>Appt Code</th>
                            <th>Appt Date Time</th>
                            <th>Total Amt</th>
                            <th>Paid Amt</th>
                            <th>Balance Amt</th>
                            <th>Paid Date</th>
                            <th>Payment Details</th>

                        </tr>

                    </thead>

                    <tbody></tbody>

                </table>

            </div>


        </div>

