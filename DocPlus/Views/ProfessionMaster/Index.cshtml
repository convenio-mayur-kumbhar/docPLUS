@using System.Reflection
@inject IStringLocalizerFactory LocalizerFactory

@{
    var Localizer = LocalizerFactory.Create("SharedResource", Assembly.GetExecutingAssembly().GetName().Name);
    ViewData["Title"] = @Localizer["Profession_Master"];
}
<style>
    .modal-dialog {
        max-width: 600px !important;
    }

    #tblProfession th:nth-child(2),
    #tblProfession th:nth-child(3),
    #tblProfession td:nth-child(2),
    #tblProfession td:nth-child(3) {
        text-align: center !important;
        white-space: nowrap;
        width: 1%; /* 👈 important: extra space remove */
    }


    #tblProfession td:nth-child(3) {
        padding-right: 5px !important; /* 👈  spacing */
    }

    #tblProfession td:nth-child(2) {
        padding-right: 8px !important;
    }
  
</style>


<!-- Subheader -->
<div class="kt-subheader kt-grid__item" id="kt_subheader">

    <div class="kt-subheader__main">

        <div class="kt-subheader__breadcrumbs">

            <a asp-controller="Dashboard" asp-action="Index" class="kt-subheader__breadcrumbs-home">
                <i class="flaticon2-shelter"></i>
            </a>

            <span class="kt-subheader__breadcrumbs-separator"></span>

            <a href="javascript:;" class="kt-subheader__breadcrumbs-link">
                @Localizer["Basic_Settings"]
            </a>

            <span class="kt-subheader__breadcrumbs-separator"></span>

            <a asp-controller="ProfessionMaster" asp-action="Index" class="kt-subheader__breadcrumbs-link">
                @Localizer["Profession_Master"]
            </a>

        </div>
    </div>
    <!-- RIGHT SIDE → Buttons -->
    <div class="kt-subheader__toolbar d-flex">

        <button ="javascript:;" id="btnAddProfession"
           class="btn btn-brand btn-elevate btn-icon-sm mr-2"
                onclick="profession.SetForAdd();" title="@Localizer["Add_Profession"]">
            <i class="fas fa-plus-circle"></i> @Localizer["Add_Profession"]
        </button>

        <div id="divExport">
            <button type="button"
                    class="btn btn-default btn-icon-sm"
                    onclick="profession.Export();" title="@Localizer["Export"]">
                <i class="la la-download"></i> Export
            </button>
        </div>

    </div>

</div>



<!-- Main Grid -->
<div class="kt-portlet kt-portlet--mobile">
  
    <div class="kt-portlet__body table-responsive" id="divIDViewProfession" style="display:none;">
        <!--begin: Datatable -->
        <table class="table table-striped table-hover table-checkable" id="tblProfession">

            <thead>
                <tr>
                    <th> @Localizer["Profession"]</th>
                    <th style=" text-align:right;"> @Localizer["Edit"]</th>
                    <th style=" text-align:right;"> @Localizer["Delete"]</th>
                </tr>
            </thead>

            <tbody></tbody>

        </table>
    </div>

</div>



<!-- Add Profession Modal -->
<div class="modal fade" id="ProfessionModal">

    <div class="modal-dialog modal-dialog-centered">

        <div class="modal-content">

            <div class="modal-header">

                <h5 class="modal-title" title="@Localizer["Add_Profession"]">@Localizer["Add_Profession"]</h5>

                <button type="button" class="close"
                        data-dismiss="modal"
                        onclick="profession.SetForClose();" title="@Localizer["Close"]"></button>

            </div>

            <div class="modal-body">

                <form id="frmProfession">

                    <input type="text"
                           id="txtProfession"
                           class="form-control"
                           placeholder="@Localizer["Enter_Profession"]" />

                </form>

            </div>

            <div class="modal-footer">

                <button class="btn btn-success"
                        onclick="profession.AddUpdate();" title="@Localizer["Save"]">
                    @Localizer["Save"]
                </button>

                <button type="button"
                        class="btn btn-warning"
                        onclick="profession.ResetData();" title="@Localizer["Reset"]">
                    @Localizer["Reset"]
                </button>

                <button class="btn btn-danger"
                        onclick="profession.SetForClose();" title="@Localizer["Close"]">
                    @Localizer["Close"]
                </button>

            </div>

        </div>

    </div>

</div>
<form id="__AjaxAntiForgeryForm">
    @Html.AntiForgeryToken()
</form>
<input type="hidden" id="hdnProfessionID" value="0" />
<script id="Grid_Data_Template_tblProfession" type="text/x-jquery-tmpl">
    <tr>
        <td>${professioN_NAME}</td>

        <!-- Edit -->
        <td>
            <i class="fa fa-edit text-primary action-icon" 
               onclick="profession.Edit(${professioN_ID})" title="@Localizer["Edit"]" style="cursor:pointer"></i>
        </td>

        <!-- Delete -->
        <td>
            <i class="fa fa-trash text-danger action-icon"
               onclick="profession.Delete(${professioN_ID},'${professioN_NAME}')" title="@Localizer["Delete"]" style="cursor:pointer"></i>
        </td>
    </tr>
</script>
<script src="~/scripts/ProfessionMaster.js"></script>

