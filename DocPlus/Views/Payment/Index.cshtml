@{
    ViewData["Title"] = "Payment";
}

<style>
    body,
    .page-content,
    .form-control,
    .table,
    .btn,
    label,
    select,
    input {
        font-size: 13px !important;
        font-family: 'Open Sans', 'Segoe UI', Arial, sans-serif !important;
    }

        .table th {
            font-weight: 400 !important;
        }

        .table td {
            font-size: 13px !important;
        }
</style>

<div class="kt-subheader kt-grid__item" id="kt_subheader">

    <div class="kt-subheader__main">

        <span class="kt-subheader__separator kt-hidden"></span>

        <div class="kt-subheader__breadcrumbs">

            <a asp-controller="Admin" asp-action="Payments" class="kt-subheader__breadcrumbs-home">
                <i class="flaticon2-shelter"></i>
            </a>

            <span class="kt-subheader__breadcrumbs-separator"></span>

            <a asp-controller="Admin" asp-action="Payments" class="kt-subheader__breadcrumbs-link">
                Payments
            </a>

        </div>

    </div>

</div>


<div id="divGrid">

    <form id="frmPaymentSearch">

        <div class="kt-portlet kt-portlet--mobile p-2 mb-1">

            <div class="form-group row">

                <div class="col-xs-12 col-md-12 col-lg-12" style="display:inline-flex;">


                    <div class="col-md-3">
                        <label>Patient</label>

                        <select class="form-control" id="ddlPatient">

                            <option value="">Select Patient</option>
                            <option>Abeer Bagul</option>
                            <option>Rohan Patil</option>
                            <option>Sneha Kulkarni</option>

                        </select>
                    </div>


                    <div class="col-md-3">
                        <label>Appointment Date</label>

                        <input type="text"
                               id="txtApptDate"
                               class="form-control date-picker"
                               placeholder="Select Date">

                    </div>


                    <div class="col-md-3">
                        <label>Mode</label>

                        <select class="form-control" id="ddlMode">

                            <option value="">All</option>
                            <option>Cash</option>
                            <option>Card</option>
                            <option>Cheque</option>
                            <option>Bank</option>

                        </select>

                    </div>


                    <div class="col-md-3" style="padding-top:23px">

                        <input type="button"
                               class="btn btn-primary"
                               value="Search"
                               onclick="Payment.Search()" />

                        <button type="button"
                                class="btn btn-danger"
                                onclick="Payment.Reset()">
                            Reset
                        </button>

                    </div>


                </div>

            </div>

        </div>



        <div class="kt-portlet kt-portlet--mobile">

            <div class="kt-portlet__head kt-portlet__head--lg">

                <div class="kt-portlet__head-label"></div>

                <div class="kt-portlet__head-toolbar">

                    <div class="kt-portlet__head-wrapper">

                        <div class="kt-portlet__head-actions">

                            <span>

                                <a href="javascript:;"
                                   class="btn btn-brand btn-elevate btn-icon-sm"
                                   onclick="Payment.OpenPanel()">

                                    <i class="fas fa-plus-circle"></i>
                                    Add Payment

                                </a>

                            </span>

                        </div>

                    </div>

                </div>

            </div>



            <div class="kt-portlet__body table-responsive">

                <table class="table table-striped table-hover table-checkable">

                    <thead>

                        <tr>

                            <th>Patient</th>
                            <th>Appt Date</th>
                            <th>Appt Time</th>
                            <th>Total Amt</th>
                            <th>Paid Amt</th>
                            <th>Paid Date</th>
                            <th>Mode</th>

                        </tr>

                    </thead>


                    <tbody id="paymentTableBody">

                        <tr>

                            <td>Abeer Bagul</td>
                            <td>10-Feb-2026</td>
                            <td>11:00 AM</td>
                            <td>2000</td>
                            <td>1500</td>
                            <td>10-Feb-2026</td>
                            <td>Cash</td>

                        </tr>

                        <tr>

                            <td>Rohan Patil</td>
                            <td>12-Feb-2026</td>
                            <td>02:00 PM</td>
                            <td>3000</td>
                            <td>3000</td>
                            <td>12-Feb-2026</td>
                            <td>Card</td>

                        </tr>

                    </tbody>

                </table>

            </div>

        </div>


        <!-- PAYMENT FORM PANEL -->

        <div class="kt-portlet kt-portlet--mobile" id="paymentPanel" style="display:none;">

            <div class="kt-portlet__head">

                <h5 style="padding:10px">Payment Details</h5>

            </div>

            <div class="kt-portlet__body">

                <div class="row">

                    <div class="col-md-3">

                        <label>Total Amt</label>
                        <input type="text" id="txtTotalAmt" class="form-control">

                    </div>


                    <div class="col-md-3">

                        <label>Paid Amt</label>
                        <input type="text" id="txtPaidAmt" class="form-control">

                    </div>


                    <div class="col-md-3">

                        <label>Balance Amt</label>
                        <input type="text" id="txtBalAmt" class="form-control">

                    </div>


                    <div class="col-md-3">

                        <label>Paid Date</label>

                        <input type="text"
                               id="txtPaidDate"
                               class="form-control date-picker">

                    </div>

                </div>


                <br>

                <label>Mode</label>

                <br>

                <label class="radio-inline">
                    <input type="radio" name="mode" value="Cash"> Cash
                </label>

                <label class="radio-inline">
                    <input type="radio" name="mode" value="Card"> Card
                </label>

                <label class="radio-inline">
                    <input type="radio" name="mode" value="Cheque"> Cheque
                </label>

                <label class="radio-inline">
                    <input type="radio" name="mode" value="Bank"> Bank
                </label>


                <br><br>

                <button class="btn btn-primary" onclick="Payment.Save()">
                    Save Payment
                </button>

                <button class="btn btn-danger" onclick="Payment.ClosePanel()">
                    Close
                </button>

            </div>

        </div>

    </form>

</div>



<script>

    var Payment = {

    Search:function(){

    alert("Search Payment");

    },

    Reset:function(){

    $("#ddlPatient").val("");
    $("#txtApptDate").val("");
    $("#ddlMode").val("");

    },

    OpenPanel:function(){

    $("#paymentPanel").slideDown();

    },

    ClosePanel:function(){

    $("#paymentPanel").slideUp();

    },

    Save:function(){

    alert("Payment Saved");

    }

    }

</script>