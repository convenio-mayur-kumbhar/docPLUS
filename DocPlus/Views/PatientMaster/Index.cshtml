@section Scripts {

    <script src="~/assets/js/jquery.dataTables.min.js"></script>
    <script src="~/assets/js/dataTables.bootstrap.min.js"></script>


    <script>

        var PatientReport={

        BindData:function(){

        var patient=$("#ddlPatient").val();
        var isAll=$("#chkAllPatients").is(":checked");


        var data=[

        {
        PatientId:"1",
        Name:"TOKEKAR AARYAN",
        Address:"Pashan Pune",
        DOB:"19-May-2004",
        Gender:"Male",
        TeleNo:"",
        MobileNo:"9021953535",
        Email:"tokekar@gmail.com",
        Category:"Adult",
        Status:"Private",
        Occupation:"Student",
        Remarks:"Referred by his mother",
        ReferredBy:"Mrs Tokekar",
        NextOfKin:"Father - Mr Tokekar",
        OtherProfessional:"Dr Sharma"
        },

        {
        PatientId:"2",
        Name:"Rahul Sharma",
        Address:"Baner Pune",
        DOB:"10-Jan-1998",
        Gender:"Male",
        TeleNo:"",
        MobileNo:"9876543210",
        Email:"rahul@gmail.com",
        Category:"Adult",
        Status:"General",
        Occupation:"Engineer",
        Remarks:"Walk-in patient",
        ReferredBy:"",
        NextOfKin:"Mother - Sushma Sharma",
        OtherProfessional:"Dr Patil"
        }

        ];


        var filtered=[];


        if(isAll){

        filtered=data;

        }
        else if(patient!=""){

        filtered=data.filter(function(p){

        return p.PatientId==patient;

        });

        }
        else{

        alert("Select Patient or Check All Patients");

        return;

        }


        var tbody=$("#tblPatientReport tbody");

        tbody.empty();


        $.each(filtered,function(i,item){

        var row="<tr>"+

        "<td>"+item.Name+"</td>"+
        "<td>"+item.Address+"</td>"+
        "<td>"+item.DOB+"</td>"+
        "<td>"+item.Gender+"</td>"+
        "<td>"+item.TeleNo+"</td>"+
        "<td>"+item.MobileNo+"</td>"+
        "<td>"+item.Email+"</td>"+
        "<td>"+item.Category+"</td>"+
        "<td>"+item.Status+"</td>"+
        "<td>"+item.Occupation+"</td>"+
        "<td>"+item.Remarks+"</td>"+
        "<td>"+item.ReferredBy+"</td>"+
        "<td>"+item.NextOfKin+"</td>"+
        "<td>"+item.OtherProfessional+"</td>"+

        "</tr>";

        tbody.append(row);

        });


        $("#divPatientGrid").show();


        $("#tblPatientReport").DataTable({

        destroy:true,
        pageLength:10,
        searching:true,
        paging:true,
        ordering:true,
        info:true

        });

        },



        ResetData:function(){

        $("#ddlPatient").val("");

        $("#chkAllPatients").prop("checked",false);

        $("#tblPatientReport tbody").empty();

        $("#divPatientGrid").hide();

        },



        ExportExcel:function(){

        var table=document.getElementById("tblPatientReport");

        var html=table.outerHTML;

        var url='data:application/vnd.ms-excel,'+escape(html);

        var link=document.createElement("a");

        link.href=url;

        link.download="PatientMasterReport.xls";

        link.click();

        }

        };

    </script>

}