                    <label>Patient</label>

                    <select id="ddlPatient" class="form-control">

                        <option value="">Select Patient</option>
                        <option value="1">TOKEKAR AARYAN</option>
                        <option value="2">Rahul Sharma</option>
                        <option value="3">Sneha Patil</option>

                    </select>

                </div>


                <div class="col-md-2" style="margin-top:30px">

                    <label>

                        <input type="checkbox" id="chkAllPatients">

