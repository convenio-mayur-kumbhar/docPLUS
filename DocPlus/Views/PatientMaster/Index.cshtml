<style>
    .tableFixHead {
        height: 410px !important;
    }
</style>


<!-- SUBHEADER (Same like Bill Page) -->

<div class="kt-subheader kt-grid__item" id="kt_subheader" style="height:40px;">

    <div class="kt-subheader__main">

        <span class="kt-subheader__separator kt-hidden"></span>

        <div class="kt-subheader__breadcrumbs">

            <a asp-controller="Home" asp-action="Index" class="kt-subheader__breadcrumbs-home">
                <i class="flaticon2-shelter"></i>
            </a>

            <span class="kt-subheader__breadcrumbs-separator"></span>

            <a href="#" class="kt-subheader__breadcrumbs-link">
                Report
            </a>

            <span class="kt-subheader__breadcrumbs-separator"></span>

            <a href="#" class="kt-subheader__breadcrumbs-link">
                Patient Master Report
            </a>

        </div>

    </div>

</div>



<div class="kt-portlet kt-portlet--mobile">

    <div class="kt-portlet__head">

        <div class="kt-portlet__head-label">

            <h3 class="kt-portlet__head-title">

                Patient Master Report

            </h3>

        </div>


        <div class="kt-portlet__head-toolbar">

            <a href="javascript:;" id="btnExportToExcel"
               onclick="PatientReport.ExportExcel();"
               class="btn btn-success btn-icon-sm"
               style="display:none;">

                <i class="fa fa-file-excel"></i>

                Export Excel

            </a>

        </div>

    </div>



    <div class="kt-portlet__body">


        <!-- SEARCH SECTION -->

        <form id="frmPatientReport">

            <div class="row mb-3">

                <div class="col-md-4">

                    <label>Patient</label>

                    <select id="ddlPatient" class="form-control">

                        <option value="">Select Patient</option>
                        <option value="1">TOKEKAR AARYAN</option>
                        <option value="2">Rahul Sharma</option>
                        <option value="3">Sneha Patil</option>

                    </select>

                </div>


                <div class="col-md-2" style="padding-top:30px;">

                    <label>

                        <input type="checkbox" id="chkAllPatients">

                        All Patients

                    </label>

                </div>


                <div class="col-md-4" style="padding-top:25px;">

                    <button type="button"
                            onclick="PatientReport.Search();"
                            class="btn btn-primary">

                        <i class="fa fa-search"></i> Search

                    </button>


                    <button type="button"
                            class="btn btn-warning"
                            onclick="PatientReport.Reset();">

                        <i class="fa fa-history"></i> Reset

                    </button>

                </div>

            </div>

        </form>



        <!-- GRID -->

        <div class="table-responsive tableFixHead" id="divPatientGrid" style="display:none">

            <table id="tblPatientReport"
                   class="table table-striped table-bordered table-hover">

                <thead>

                    <tr>

                        <th>Name</th>
                        <th>Address</th>
                        <th>Date Of Birth</th>
                        <th>Gender</th>
                        <th>Tele No</th>
                        <th>Mobile No</th>
                        <th>Email</th>
                        <th>Category</th>
                        <th>Status</th>
                        <th>Occupation</th>
                        <th>Remarks</th>
                        <th>Referred By</th>
                        <th>Next Of Kin</th>
                        <th>Other Professionals Involved</th>

                    </tr>

                </thead>

                <tbody></tbody>

            </table>

        </div>

    </div>

</div>



<script id="Grid_Data_Template_tblPatientReport" type="text/x-jquery-tmpl">

    <tr>

    <td>${Name}</td>
    <td>${Address}</td>
    <td>${DOB}</td>
    <td>${Gender}</td>
    <td>${TeleNo}</td>
    <td>${MobileNo}</td>
    <td>${Email}</td>
    <td>${Category}</td>
    <td>${Status}</td>
    <td>${Occupation}</td>
    <td>${Remarks}</td>
    <td>${ReferredBy}</td>
    <td>${NextOfKin}</td>
    <td>${OtherProfessional}</td>

    </tr>

</script>



@section Scripts {

    <script src="https://ajax.aspnetcdn.com/ajax/jquery.templates/beta1/jquery.tmpl.min.js"></script>
    <script src="~/assets/js/jquery.dataTables.min.js"></script>
    <script src="~/assets/js/dataTables.bootstrap.min.js"></script>


    <script>

        var PatientReport = {

        Search: function () {

        var selectedPatient = $("#ddlPatient").val();

        var isAllChecked = $("#chkAllPatients").is(":checked");


        var data = [

        {
        PatientId: "1",
        Name: "TOKEKAR AARYAN",
        Address: "Pashan Pune",
        DOB: "19-May-2004",
        Gender: "Male",
        TeleNo: "",
        MobileNo: "9021953535",
        Email: "tokekar@gmail.com",
        Category: "Adult",
        Status: "Private",
        Occupation: "Student",
        Remarks: "Referred by his mother",
        ReferredBy: "Mrs Tokekar",
        NextOfKin: "Father - Mr Tokekar",
        OtherProfessional: "Dr. Sharma"
        },

        {
        PatientId: "2",
        Name: "Rahul Sharma",
        Address: "Baner Pune",
        DOB: "10-Jan-1998",
        Gender: "Male",
        TeleNo: "",
        MobileNo: "9876543210",
        Email: "rahul@gmail.com",
        Category: "Adult",
        Status: "General",
        Occupation: "Engineer",
        Remarks: "Walk-in patient",
        ReferredBy: "",
        NextOfKin: "Mother - Sushma Sharma",
        OtherProfessional: "Dr. Patil"
        },

        {
        PatientId: "3",
        Name: "Sneha Patil",
        Address: "Wakad Pune",
        DOB: "05-Mar-2000",
        Gender: "Female",
        TeleNo: "",
        MobileNo: "9090909090",
        Email: "sneha@gmail.com",
        Category: "Adult",
        Status: "Private",
        Occupation: "Designer",
        Remarks: "Referral case",
        ReferredBy: "Dr Kulkarni",
        NextOfKin: "Mother - Sunita Patil",
        OtherProfessional: "Dr. Mehta"
        }

        ];


        var filteredData = [];


        if (isAllChecked) {

        filteredData = data;

        }

        else if (selectedPatient != "") {

        filteredData = data.filter(function (p) {

        return p.PatientId == selectedPatient;

        });

        }

        else {

        alert("Please select patient or check All Patients");

        return;

        }



        if ($.fn.DataTable.isDataTable('#tblPatientReport')) {

        $('#tblPatientReport').DataTable().destroy();

        }



        $("#tblPatientReport tbody").empty();


        $("#Grid_Data_Template_tblPatientReport")
        .tmpl(filteredData)
        .appendTo("#tblPatientReport tbody");


        $("#divPatientGrid").show();

        $("#btnExportToExcel").show();



        $('#tblPatientReport').DataTable({

        pageLength: 5,

        lengthMenu: [[5,10,25,50,-1],[5,10,25,50,"All"]],

        searching: true,

        paging: true,

        ordering: true,

        info: true

        });

        },



        Reset: function () {

        $("#ddlPatient").val("");

        $("#chkAllPatients").prop("checked", false);


        if ($.fn.DataTable.isDataTable('#tblPatientReport')) {

        $('#tblPatientReport').DataTable().destroy();

        }


        $("#tblPatientReport tbody").empty();

        $("#divPatientGrid").hide();

        $("#btnExportToExcel").hide();

        },



        ExportExcel: function () {

        var table = document.getElementById("tblPatientReport");

        var html = table.outerHTML;


        var url = 'data:application/vnd.ms-excel,' + escape(html);


        var link = document.createElement("a");

        link.href = url;

        link.download = "PatientMasterReport.xls";

        link.click();

        }

        };

    </script>

