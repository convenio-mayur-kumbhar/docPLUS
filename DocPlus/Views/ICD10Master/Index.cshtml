@{
    ViewData["Title"] = "ICD10 Master";
}

<style>
    .modal-dialog {
        max-width: 650px !important;
    }
</style>

<!-- SUBHEADER -->

<div class="kt-subheader kt-grid__item" id="kt_subheader">

    <div class="kt-subheader__main">

        <div class="kt-subheader__breadcrumbs">

            <a asp-controller="Dashboard" asp-action="Index"
               class="kt-subheader__breadcrumbs-home"> <i class="flaticon2-shelter"></i> </a>

            <span class="kt-subheader__breadcrumbs-separator"></span>

            <a href="javascript:;" class="kt-subheader__breadcrumbs-link">
                Basic Settings
            </a>

            <span class="kt-subheader__breadcrumbs-separator"></span>

            <a asp-controller="ICD10Master" asp-action="Index"
               class="kt-subheader__breadcrumbs-link">

                ICD10 Master

            </a>

        </div>
    </div>
</div>

<!-- MAIN GRID -->

<div class="kt-portlet kt-portlet--mobile">

    <div class="kt-portlet__head kt-portlet__head--lg">

        <div class="kt-portlet__head-label">

            <span class="kt-portlet__head-icon">
                <i class="kt-font-brand fas fa-notes-medical"></i>
            </span>

            <h3 class="kt-portlet__head-title">

                ICD10 Master

            </h3>

        </div>

        <div class="kt-portlet__head-toolbar">

            <div class="kt-portlet__head-wrapper">

                <div class="kt-portlet__head-actions">

                    <button type="button"
                            class="btn btn-default btn-icon-sm"
                            onclick="ExportToExcelGrid('#tblICD','excel')">

                        <i class="la la-download"></i>
                        Export

                    </button>



                    <a href="javascript:;"
                       class="btn btn-brand btn-elevate btn-icon-sm"
                       onclick="showAddModal()">

                        <i class="fas fa-plus-circle"></i>

                        Add ICD

                    </a>

                </div>
            </div>
        </div>

    </div>

    <div class="kt-portlet__body table-responsive">

        <table class="table table-striped table-hover table-checkable"
               id="tblICD">

            <thead>

                <tr>

                    <th>ICD Code</th>

                    <th>Description</th>

                    <th style="width:120px;">Action</th>

                </tr>

            </thead>

            <tbody>

                <tr>

                    <td>F00</td>

                    <td>Dementia in Alzheimer's disease</td>

                    <td>

                        <a href="#" class="btn btn-sm btn-clean btn-icon btn-icon-md btnDelete">
                            <i class="fas fa-trash-alt text-danger"></i>
                        </a>

                    </td>

                </tr>

                <tr>

                    <td>F00.0</td>

                    <td>Dementia in Alzheimer's disease with early onset</td>

                    <td>

                        <a href="#" class="btn btn-sm btn-clean btn-icon btn-icon-md btnDelete">
                            <i class="fas fa-trash-alt text-danger"></i>
                        </a>

                    </td>

                </tr>

                <tr>

                    <td>F01</td>

                    <td>Vascular dementia</td>

                    <td>

                        <a href="#" class="btn btn-sm btn-clean btn-icon btn-icon-md btnDelete">
                            <i class="fas fa-trash-alt text-danger"></i>
                        </a>

                    </td>

                </tr>

            </tbody>

        </table>

    </div>

</div>

<!-- ADD ICD MODAL -->

<div class="modal fade" id="AddICDModal">

    <div class="modal-dialog modal-dialog-centered">

        <div class="modal-content">

            <div class="modal-header">

                <h5 class="modal-title">

                    Add ICD

                </h5>

                <button type="button"
                        class="close"
                        data-dismiss="modal"></button>

            </div>

            <div class="modal-body">

                <input type="text"
                       id="txtICDCode"
                       class="form-control"
                       placeholder="Enter ICD Code"
                       style="margin-bottom:10px;" />

<textarea id="txtDescription"
          class="form-control"
          placeholder="Enter Description"></textarea>

            </div>

            <div class="modal-footer">

                <button class="btn btn-primary"
                        onclick="saveICD()">

                    Save

                </button>

                <button class="btn btn-danger"
                        onclick="resetICD()">

                    Reset

                </button>

                <button class="btn btn-secondary"
                        data-dismiss="modal">

                    Close

                </button>

            </div>

        </div>
    </div>
</div>

@section Scripts {

    <script>

        $(document).ready(function(){

        $('#tblICD').DataTable({

        pageLength:10,
        ordering:false

        });

        });



        function showAddModal()
        {

        $("#txtICDCode").val("");
        $("#txtDescription").val("");

        $("#AddICDModal").modal("show");

        }



        function saveICD()
        {

        var code=$("#txtICDCode").val().trim();

        var desc=$("#txtDescription").val().trim();

        if(code=="")
        {
        alert("Enter ICD Code");
        return;
        }


        $('#tblICD').DataTable().row.add([

        code,
        desc,
        "<a href='#' class='btn btn-sm btn-clean btn-icon btn-icon-md btnDelete'><i class='fas fa-trash-alt text-danger'></i></a>"

        ]).draw();


        $("#AddICDModal").modal("hide");

        }



        function resetICD()
        {

        $("#txtICDCode").val("");
        $("#txtDescription").val("");

        }



        $(document).on("click",".btnDelete",function(){

        $('#tblICD').DataTable().row($(this).parents('tr')).remove().draw();

        });



        function ExportToExcelGrid(tableId,type)
        {

        alert("Export Called for "+tableId);

        }

    </script>

}
