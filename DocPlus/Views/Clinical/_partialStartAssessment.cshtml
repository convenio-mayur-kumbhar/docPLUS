                <div class="mr-4">
                    <i class="fa fa-phone" style="font-size: 15px;"></i>
                    <span id="lblViewContact" style="font-size:14px;"></span>
                </div>

                <div class="mr-4">
                    <i class="fa fa-envelope" style="font-size: 15px;"></i>
                    <span id="lblViewEmail" style="font-size:14px;"></span>
                </div>

            </div>

        </div>
