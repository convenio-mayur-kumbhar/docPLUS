                            <option value="2">@Localizer["Last_6_Months"]</option>
                            <option value="3">@Localizer["First_Contact"]</option>
                        </select>
                    </div>
                    <!-- DATE -->
                    <div class="mr-2 d-flex flex-column" style="justify-content:center;">
                        <label class="mb-2" style="line-height:1;">@Localizer["Date"]:</label>
                        <div class="input-group input-group-sm" style="width:150px;">
                            <input type="date" id="txtViewDate" class="form-control" placeholder="@Localizer["Date"]" autocomplete="off" />
                        </div>
                    </div>
                </div>

            </div>

            <!-- INFO ROW -->
            <div class="d-flex flex-wrap mt-2 ml-2">

                <div class="mr-4">
                    <i class="fa fa-id-card" style="font-size: 15px;"></i>
                    <span style="font-size:14px;">@Localizer["Reg_No"]: <span id="lblViewRegNo"></span></span>
                </div>

                <div class="mr-4">
                    <i id="iconViewGender" class="fa" style="font-size: 15px;"></i>
                    <span id="lblViewGender" style="font-size:14px;"></span>
                </div>

                <div class="mr-4">
                    <i class="fa fa-user" style="font-size: 15px;"></i>
