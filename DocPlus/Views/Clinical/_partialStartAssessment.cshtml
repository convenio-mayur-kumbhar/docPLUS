                                            NOK List
                                        </template>
                                        <thead>
                                            <tr>
                                                <th>Name</th>
                                                <th>Relation</th>
                                                <th>Address</th>
                                                <th>Tele. No.</th>
                                                <th>Mobile No.</th>
                                                <th>Email</th>
                                                <th>Remarks</th>                                                
                                            </tr>
                                        </thead>

                                        <tbody></tbody>

                                    </table>
                                    <script id="Grid_Data_Template_tblNOK" type="text/x-jquery-tmpl">
                                         <tr data-id="${noK_ID}">
                                         <td>${noK_NAME}</td>
                                         <td>${noK_RELATION}</td>
                                         <td>${noK_ADDR}</td>
                                         <td>${noK_TELENO}</td>
                                         <td>${noK_MOBNO}</td>
