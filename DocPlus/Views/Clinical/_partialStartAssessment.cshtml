@using System.Reflection
@inject IStringLocalizerFactory LocalizerFactory

@{
    var Localizer = LocalizerFactory.Create("SharedResource", Assembly.GetExecutingAssembly().GetName().Name);
}
<style>
    #leftMenu a {
        display: block;
        padding: 8px 10px;
        color: #333;
        text-decoration: none;
        border-bottom: 1px solid #e5e5e5;
    }

        #leftMenu a:hover {
            background: #f5f5f5;
        }
        /* Active left menu item */
        #leftMenu a.active {
            background: #555;
            color: #fff !important;
            border-left: 4px solid #fd397a;
        }

    /* Normal tab */
    .nav-pills .nav-link {
        color: #4a4a4a;
        background: transparent;
        padding: 8px 16px;
        margin-right: 6px;
        border-radius: 4px;
        font-weight: 500;
        transition: all 0.2s ease;
    }

        /* Hover tab */
        .nav-pills .nav-link:hover {
            background: #e9f2f5;
            color: #333;
        }

        /* Active tab (blue button like Analytics) */
        .nav-pills .nav-link.active {
            background: #1f7a8c;
            color: #fff !important;
        }

    .nav-pills .dropdown-menu {
        border-radius: 4px;
        border: 1px solid #e5e5e5;
    }

    .nav-pills .dropdown-item {
        padding: 6px 12px;
        font-size: 13px;
    }

        .nav-pills .dropdown-item:hover {
            background: #f1f1f1;
        }

    .tabs-left {
        border: 1px solid #e5e5e5;
    }

        .tabs-left li {
            float: none;
        }

            .tabs-left li a {
                display: block;
                padding: 6px 8px;
                color: #333 !important;
                border-bottom: 1px solid #e5e5e5;
            }

            .tabs-left li:last-child a {
                border-bottom: none;
            }

    .tab-pane .row {
        margin-bottom: 8px;
    }



    /* ================= RISK TITLE STYLE ================= */
    .risk-title {
        font-weight: bold;
        font-size: 15px; /* optional */
    }

    /* ================= PROGRESS TIMELINE ================= */

    .progressGroup {
        margin-bottom: 15px;
    }

    .progressHeader {
        font-weight: 600;
        font-size: 13px;
        background: #eef2f7;
        padding: 4px 10px;
        border-radius: 20px;
        display: inline-block;
        margin-bottom: 10px;
    }

    .progressNote {
        display: flex;
        align-items: flex-start;
        position: relative;
        margin-bottom: 12px;
    }

        .progressNote::before {
            content: "";
            position: absolute;
            left: 25px;
            top: 0;
            bottom: -12px;
            width: 2px;
            background: #e0e0e0;
        }

    .progressTime {
        min-width: 50px;
        height: 30px;
        background: #007bff;
        color: white;
        font-size: 11px;
        border-radius: 20px;
        text-align: center;
        line-height: 30px;
        margin-right: 10px;
        z-index: 1;
    }

    .progressText {
        background: white;
        padding: 8px 12px;
        border-radius: 6px;
        border: 1px solid #ddd;
        box-shadow: 0 1px 2px rgba(0, 0, 0, 0.08);
        flex: 1;
        font-size: 13px;
    }

    /* ================= FINAL TIMELINE ================= */

    .simpleTimeline {
        position: relative;
        margin-top: 20px;
    }

        /* 🔥 GLOBAL LINE */
        .simpleTimeline::before {
            content: "";
            position: absolute;
            top: 0;
            bottom: 0;
            left: 120px;
            width: 2px;
            background: repeating-linear-gradient( to bottom, #cfcfcf, #cfcfcf 6px, transparent 6px, transparent 12px );
        }

    /* GRID STRUCTURE */
    .timelineRow {
        display: grid;
        grid-template-columns: 100px 40px 1fr;
        align-items: center;
        margin-bottom: 25px;
        position: relative;
    }

    /* TIME */
    .timelineTime {
        text-align: right;
    }

    /* MIDDLE COLUMN */
    .timelineMiddle {
        display: flex;
        justify-content: center;
        align-items: center;
        position: relative;
    }

    /* DOT */
    .timelineDot {
        width: 10px;
        height: 10px;
        background: #4caf50;
        border-radius: 50%;
        border: 2px solid #fff;
        z-index: 2;
    }

    /* CONTENT */
    .timelineContent {
        padding-left: 10px;
    }

    /* CARD */
    .timelineCard {
        background: #fff;
        padding: 12px 16px;
        border-radius: 5px;
        font-size: 14px;
        max-width: 600px;
        box-shadow: 5px 5px 10px rgba(0,0,0,0.30)
    }

    .dateRow {
        display: grid;
        grid-template-columns: 100px 40px 1fr;
        margin: 20px 0;
    }

        .dateRow .timelineMiddle {
            display: flex;
            justify-content: center;
        }

    .timelineDateHeader {
        position: relative;
        left: 50%;
        transform: translateX(-10%); /* 🔥 centers exactly */

        background: #2f2f2f;
        color: #fff;
        padding: 5px 12px;
        border-radius: 6px;
        font-size: 12px;
        white-space: nowrap;
    }

    .timelineBullet {
        margin-left: 5px;
        padding: 2px 0;
    }

    /* ================= UTILITY CLASSES ================= */

    .note-actions {
        margin-bottom: 10px;
    }

    .addPanel {
        display: none;
        overflow: visible !important;
    }

    .note-buttons {
        margin-top: 8px;
    }

    /* Optional to fine-tune Date label spacing */
    label.mb-0 {
        line-height: 1;
        margin-bottom: 2px; /* or 0 */
    }

    .menu-group {
        display: none;
    }

        .menu-group.demographics {
            display: block;
        }

    .bg-white-force {
        background-color: #fff !important;
    }

    .button-header {
        display: flex;
        gap: 15px;
        align-items: center;
        margin-bottom: 10px;
    }

    .table-scroll-x {
        overflow-x: auto;
        width: 100%;
    }

    #physicalTable {
        width: max-content; /* 🔥 required */
        border-collapse: collapse;
    }

    .valueCellInput {
        width: 100%;
        height: 28px;
        border: 1px solid #cdcdcd;
    }

    .table-scroll-x {
        overflow-x: auto;
        width: 100%;
        max-height: 500px;
        overflow-y: auto;
        border: 1px solid #ddd;
    }

    /* important */
    #physicalTable {
        width: max-content;
        border-collapse: collapse;
    }

    /* 🔥 sticky column */
    .sticky-col {
        position: sticky;
        left: 0;
        /* background: #f8f9fa; */
        z-index: 2;
        min-width: 220px; /* match your parameter width */
    }

    /* header priority */
    #physicalTable thead th.sticky-col {
        z-index: 5;
    }

    .modal {
        z-index: 1050 !important;
    }

    .modal-backdrop {
        z-index: 1040 !important;
    }

    .note-toolbar {
        z-index: 9999 !important;
    }

    .note-editor {
        z-index: 1 !important;
    }

    .note-dropdown-menu {
        z-index: 1060 !important; /* only dropdown above */
    }

    .note-modal {
        z-index: 99999 !important;
    }

        .note-modal .close::before {
            content: '' !important;
        }

        .note-modal .close {
            font-size: 22px;
            opacity: 1;
        }

            .note-modal .close span {
                display: none; /* hide duplicate */
            }

        .note-modal .modal-header .close {
            background: none;
            border: none;
        }

            .note-modal .modal-header .close::before {
                content: '' !important;
            }
    /* 🔥 Allow dropdown to escape container */
    .note-editor.note-frame {
        overflow: visible !important;
    }

    /* 🔥 Fix dropdown stacking */
    .note-dropdown-menu {
        z-index: 9999 !important;
    }
</style>
