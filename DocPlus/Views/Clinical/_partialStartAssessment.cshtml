                                            <button class="btn btn-success btn-sm" type="button" onclick="clinical.SaveInPatients();" id="btnSaveIP" title="@Localizer["Save"]">
                                                @Localizer["Save"]
                                            </button>

                                            <button class="btn btn-danger btn-sm" id="btnCloseIP" type="button" onclick="clinical.CloseInPatients();" title="@Localizer["Close"]">
                                                @Localizer["Close"]
                                            </button>

                                        </div>

                                    </div>

                                </div>

                            </div>
                            @*----------------------------------------Attachment-------------------------------------------*@
                            <div id="attachments" class="tab-pane fade assessment-section">

                                <div style="margin-bottom:10px;">
                                    <button class="btn btn-secondary btn-sm" id="btnOpenAttachment" title="@Localizer["Add"]">
                                        @Localizer["Add"] Attachment
                                    </button>
                                </div>

                                <!-- FORM BOX (Same style as Other Professionals) -->
                                <div class="attachmentPanel" style="display:none;">

                                    <div style="border:1px solid #ddd;padding:12px;background:#f9f9f9;">

                                        <div class="row">
                                            <div class="col-md-8">
                                                <label>Doc Path</label>
                                                <input type="file" class="form-control" id="fileAttachment">
                                            </div>
                                        </div>

                                        <div class="row">
                                            <div class="col-md-6">
                                                <label>Doc Name</label>
                                                <input type="text" class="form-control" id="txtDocName">
                                            </div>
                                        </div>

                                        <div class="row">
                                            <div class="col-md-12">
                                                <label>Doc Description</label>
                                                <textarea class="form-control" id="txtDocDescription"></textarea>
                                            </div>
                                        </div>

                                        <!-- BUTTONS -->
                                        <div style="margin-top:10px;display:flex;justify-content:flex-start;gap:8px;">

                                            <button class="btn btn-success btn-sm" id="btnSaveAttachment" title="@Localizer["Save"]">
                                                <i class="fa fa-save"></i> @Localizer["Save"]
                                            </button>

                                            <button class="btn btn-danger btn-sm" id="btnCloseAttachment" title="@Localizer["Close"]">
                                                @Localizer["Close"]
                                            </button>

                                        </div>

                                    </div>

                                </div>

                            </div>
                            @*------------------------------Medical Certificates---------------------------------------*@
                            <div id="medicalcert" class="tab-pane fade assessment-section">

                                <!-- TOP BUTTONS -->
                                <div class="topButtons" style="display:flex; gap:8px; margin-bottom:10px;">
                                    <button class="btn btn-primary btn-sm btnQuickInfo" title="@Localizer["Quick_Information"]">
                                        @Localizer["Quick_Information"]
                                    </button>

                                    <button class="btn btn-secondary btn-sm " title="@Localizer["Add"]">
                                        @Localizer["Add"]
                                    </button>
                                </div>

                                <!-- FORM PANEL -->
                                <div class="medicalPanel" style="display:none;">

                                    <!-- SAME BACKGROUND STYLE -->
                                    <div style="border:1px solid #ddd;padding:12px;background:#f9f9f9;">

                                        <div class="container-fluid">

                                            <div class="row">

                                                <!-- Assessment From -->
                                                <div class="col-md-6">
                                                    <div class="form-group row">
                                                        <label class="col-md-4 text-right">Assessment From:</label>

                                                        <div class="input-group date">
                                                            <input type="text"
                                                                   class="form-control date-picker txnDate mcFromDate"
                                                                   placeholder="DD-MMM-YYYY"
                                                                   maxlength="11"
                                                                   style="height:32px;" />

                                                            <span class="input-group-addon" style="padding:6px 10px;">
                                                                <span class="fa fa-calendar"></span>
                                                            </span>
                                                        </div>
                                                    </div>
                                                </div>

                                                <!-- Assessment Date -->
                                                <div class="col-md-6">
                                                    <div class="form-group row">
                                                        <label class="col-md-4 text-right">Assessment Date:</label>

                                                        <div class="input-group date">
                                                            <input type="text"
                                                                   class="form-control date-picker txnDate mcAssessmentDate"
                                                                   placeholder="DD-MMM-YYYY"
                                                                   maxlength="11"
                                                                   style="height:32px;" />

                                                            <span class="input-group-addon" style="padding:6px 10px;">
                                                                <span class="fa fa-calendar"></span>
                                                            </span>
                                                        </div>
                                                    </div>
                                                </div>

                                            </div>

                                            <!-- Suffering -->
                                            <div class="form-group row">
                                                <label class="col-md-2 text-right">Suffering From:</label>

                                                <div class="col-md-10">
                                                    <textarea class="form-control mcSuffering" rows="3"></textarea>
                                                </div>
                                            </div>

                                            <!-- Consequences -->
                                            <div class="form-group row">
                                                <label class="col-md-2 text-right">Consequences:</label>

                                                <div class="col-md-10">
                                                    <textarea class="form-control mcConsequences" rows="3"></textarea>
                                                </div>
                                            </div>

                                            <!-- Recommendations -->
                                            <div class="form-group row">
                                                <label class="col-md-2 text-right">Recommendations:</label>

                                                <div class="col-md-10">
                                                    <textarea class="form-control mcRecommendations" rows="3"></textarea>
                                                </div>
                                            </div>

                                            <div class="text-center" style="margin-top:20px;">

                                                <button class="btn btn-success btn-sm" id="btnSaveMC" title="@Localizer["Save"]">
                                                    @Localizer["Save"]
                                                </button>

                                                <button class="btn btn-info btn-sm" id="btnSavePrintMC" title="@Localizer["Save_Print"]">
                                                    @Localizer["Save_Print"]"
                                                </button>

                                                <button class="btn btn-danger btn-sm" id="btnCloseMC" title="@Localizer["Close"]">
                                                    @Localizer["Close"]
                                                </button>

                                            </div>

                                        </div>

                                    </div>

                                </div>

                            </div>
                            @*----------------------------Old Medical--------------------------*@
                            <div id="oldmedicert" class="tab-pane fade assessment-section ">
                                <div class="oldMedicalPanel">

                                    <div style="margin-bottom:15px;">
                                        <label style="margin-right:15px;">Select Date:</label>

                                        <select id="ddlOldMedicalDate"
                                                class="form-control"
                                                style="width:200px; display:inline-block;">
                                            <option value="">-- Select Date --</option>
                                        </select>
                                    </div>

                                    <button type="button" title="@Localizer["Proceed"]"
                                            class="btn btn-success btn-sm"
                                            id="btnProceedOldCertificate">
                                        Proceed
                                    </button>
                                </div>
                            </div>
                            @*----------------------------Psychiatric Report----------------------------------------*@
                            <div id="psyreport" class="tab-pane fade assessment-section">
                            </div>

                        </div>
                    </div>
                </div>
            </div>
            <input type="hidden" id="hf_PatientID" value="" />
            <input type="hidden" id="hf_AppointmentID" value="" />
        </div>
    </form>
</div>
