@using System.Reflection
@inject IStringLocalizerFactory LocalizerFactory

@{
    var Localizer = LocalizerFactory.Create("SharedResource", Assembly.GetExecutingAssembly().GetName().Name);
}

<style>
    #leftMenu a {
        display: block;
        padding: 8px 10px;
        color: #333;
        text-decoration: none;
        border-bottom: 1px solid #e5e5e5;
    }

        #leftMenu a:hover {
            background: #f5f5f5;
        }
        /* Active left menu item */
        #leftMenu a.active {
            background: #555;
            color: #fff !important;
            border-left: 4px solid #fd397a;
        }

    /* Normal tab */
    .nav-pills .nav-link {
        color: #4a4a4a;
        background: transparent;
        padding: 8px 16px;
        margin-right: 6px;
        border-radius: 4px;
        font-weight: 500;
        transition: all 0.2s ease;
    }

        /* Hover tab */
        .nav-pills .nav-link:hover {
            background: #e9f2f5;
            color: #333;
        }

        /* Active tab (blue button like Analytics) */
        .nav-pills .nav-link.active {
            background: #1f7a8c;
            color: #fff !important;
        }

    .nav-pills .dropdown-menu {
        border-radius: 4px;
        border: 1px solid #e5e5e5;
    }

    .nav-pills .dropdown-item {
        padding: 6px 12px;
        font-size: 13px;
    }

        .nav-pills .dropdown-item:hover {
            background: #f1f1f1;
        }

    .tabs-left {
        border: 1px solid #e5e5e5;
    }

        .tabs-left li {
            float: none;
        }

            .tabs-left li a {
                display: block;
                padding: 6px 8px;
                color: #333 !important;
                border-bottom: 1px solid #e5e5e5;
            }

            .tabs-left li:last-child a {
                border-bottom: none;
            }

    .tab-pane .row {
        margin-bottom: 8px;
    }



    /* ================= RISK TITLE STYLE ================= */
    .risk-title {
        font-weight: bold;
        font-size: 15px; /* optional */
    }

    /* ================= PROGRESS TIMELINE ================= */

    .progressGroup {
        margin-bottom: 15px;
    }

    .progressHeader {
        font-weight: 600;
        font-size: 13px;
        background: #eef2f7;
        padding: 4px 10px;
        border-radius: 20px;
        display: inline-block;
        margin-bottom: 10px;
    }

    .progressNote {
        display: flex;
        align-items: flex-start;
        position: relative;
        margin-bottom: 12px;
    }

        .progressNote::before {
            content: "";
            position: absolute;
            left: 25px;
            top: 0;
            bottom: -12px;
            width: 2px;
            background: #e0e0e0;
        }

    .progressTime {
        min-width: 50px;
        height: 30px;
        background: #007bff;
        color: white;
        font-size: 11px;
        border-radius: 20px;
        text-align: center;
        line-height: 30px;
        margin-right: 10px;
        z-index: 1;
    }

    .progressText {
        background: white;
        padding: 8px 12px;
        border-radius: 6px;
        border: 1px solid #ddd;
        box-shadow: 0 1px 2px rgba(0, 0, 0, 0.08);
        flex: 1;
        font-size: 13px;
    }

    /* ================= TIMELINE COMPONENT ================= */

    .timelineContainer {
        margin-top: 20px;
        position: relative;
    }

    .timelineItem {
        display: flex;
        align-items: flex-start;
        margin-bottom: 20px;
        position: relative;
    }

    .timelineLeft {
        padding-right: 15px;
    }

    .timelineDate {
        font-weight: 600;
        color: #333;
        font-size: 14px;
    }

    .timelineTime {
        font-size: 12px;
        color: #888;
        margin-top: 2px;
    }

    .timelineMiddle {
        width: 3px;
        background: #4CAF50;
        margin-right: 15px;
        border-radius: 2px;
        min-height: 60px;
    }

    .timelineRight {
        flex: 1;
        background: linear-gradient(135deg, #f8fafc, #eef2f7);
        border-radius: 10px;
        padding: 14px 16px;
        border: 1px solid #e2e6ea;
        box-shadow: 0 2px 6px rgba(0, 0, 0, 0.05);
        font-size: 14px;
        line-height: 1.5;
        transition: all 0.2s;
    }

        .timelineRight:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.08);
        }

    /* ================= UTILITY CLASSES ================= */

    .note-actions {
        margin-bottom: 10px;
    }

    .addPanel {
        /*  display: none; */
        background: #f9f9f9;
        padding: 10px;
        border-radius: 6px;
        border: 1px solid #ddd;
        margin-bottom: 10px;
    }

    .note-buttons {
        margin-top: 8px;
    }

    /* Optional to fine-tune Date label spacing */
    label.mb-0 {
        line-height: 1;
        margin-bottom: 2px; /* or 0 */
    }

    .menu-group {
        display: none;
    }

        .menu-group.demographics {
            display: block;
        }
</style>
<div class="kt-subheader kt-grid__item" id="kt_subheader">
