@model DocPlus.Entities.ViewModels.Login_VM
@{
    ViewData["Title"] = "Login";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">

<!-- begin::Head -->
<head>

    <!--begin::Base Path (base relative path for assets of this page) -->
    <base href="../../../../">

    <!--end::Base Path -->
    <meta charset="utf-8" />
    <title>@ViewData["Title"]</title>
    <meta name="description" content="Login page example">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

    <!--begin::Fonts -->
    <script src="https://ajax.googleapis.com/ajax/libs/webfont/1.6.16/webfont.js"></script>
    <script>
        WebFont.load({
            google: {
                "families": ["Poppins:300,400,500,600,700", "Roboto:300,400,500,600,700"]
            },
            active: function () {
                sessionStorage.fonts = true;
            }
        });
    </script>

    <!--end::Fonts -->
    <!--begin::Page Custom Styles(used by this page) -->
    <link href="~/assets/css/demo1/pages/general/login/login-1.min.css" asp-append-version="true" rel="stylesheet" type="text/css" />

    <!--end::Page Custom Styles -->
    <!--begin:: Global Mandatory Vendors -->
    <link href="~/assets/vendors/general/perfect-scrollbar/css/perfect-scrollbar.css" asp-append-version="true" rel="stylesheet" type="text/css" />

    <!--end:: Global Mandatory Vendors -->
    <!--begin::Global Theme Styles(used by all pages) -->
    <link href="~/assets/css/demo1/style.bundle.min.css" asp-append-version="true" rel="stylesheet" type="text/css" />
    <link href="~/assets/css/custom/Loader.css" asp-append-version="true" rel="stylesheet" />
    <!--end::Global Theme Styles -->
    <link href="~/assets/css/NewTheme.css" asp-append-version="true" rel="stylesheet" />
    <link rel="shortcut icon" href="~/assets/images/A2A_Logo.ico" />
    <link href="~/assets/vendors/general/@@fortawesome/fontawesome-free/css/all.min.css" asp-append-version="true" rel="stylesheet" type="text/css" />
    <style>
        @@media (min-width: 481px) and (max-width: 767px) {
            .kt-login.kt-login--v1 .kt-login__aside .kt-login__title {
                font-size: 1rem !important;
            }

            .kt-login.kt-login--v1 .kt-login__wrapper .kt-login__body .kt-login__form .kt-login__title {
                margin-bottom: 0rem;
            }

            .kt-login.kt-login--v1 .kt-login__wrapper .kt-login__body .kt-login__form .kt-form {
                margin: 2rem auto;
            }

            .kt-login.kt-login--v1 .kt-login__aside .kt-login__subtitle {
                margin: 1rem 0;
            }

            .kt-login.kt-login--v1 .kt-login__aside .kt-login__info {
                margin-top: 0rem;
            }

            .kt-login.kt-login--v1 .kt-login__wrapper {
                padding: 1rem 1.5rem;
            }
        }

        @@media (min-width: 320px) and (max-width: 480px) {
            .kt-login.kt-login--v1 .kt-login__aside .kt-login__title {
                font-size: 1rem !important;
            }

            .kt-login.kt-login--v1 .kt-login__wrapper .kt-login__body .kt-login__form .kt-login__title {
                margin-bottom: 0rem;
            }

            .kt-login.kt-login--v1 .kt-login__wrapper .kt-login__body .kt-login__form .kt-form {
                margin: 2rem auto;
            }

            .kt-login.kt-login--v1 .kt-login__aside .kt-login__subtitle {
                margin: 1rem 0;
            }

            .kt-login.kt-login--v1 .kt-login__aside .kt-login__info {
                margin-top: 0rem;
            }

            .kt-login.kt-login--v1 .kt-login__wrapper {
                padding: 1rem 1.5rem;
            }
        }

        .login-slogan {
            font-size: 18px;
            opacity: 0.8;
            margin-top: 10px;
            color: #fff !important;
        }

        .login-bg {
            position: relative;
            height: 100%; /* 🔥 KEY FIX */
            min-height: 100vh; /* fallback */
            background-image: url('/assets/images/login_background.png');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            overflow: hidden;
        }

            /* Overlay for opacity */
            .login-bg::before {
                content: "";
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                inset:0;
                background: rgba(0, 0, 0, 0.5); /* 🔥 opacity layer */
                z-index: 1;
            }

        /* Keep content above overlay */
        .kt-login__body {
            position: relative;
            z-index: 2;
        }

    </style>
</head>

<!-- end::Head -->
<!-- begin::Body -->
<body class="kt-quick-panel--right kt-demo-panel--right kt-offcanvas-panel--right kt-header--fixed kt-header-mobile--fixed kt-subheader--fixed kt-subheader--enabled kt-subheader--solid kt-aside--enabled kt-aside--fixed kt-page--loading">
    <!-- begin:: Page -->
    <div class="kt-grid kt-grid--ver kt-grid--root">
        <div class="kt-grid kt-grid--hor kt-grid--root  kt-login kt-login--v1" id="kt_login">
            <div class="kt-grid__item kt-grid__item--fluid kt-grid kt-grid--desktop kt-grid--ver-desktop kt-grid--hor-tablet-and-mobile">

                <!--begin::Aside-->
                <div class="kt-grid__item kt-grid__item--order-tablet-and-mobile-2 kt-grid kt-grid--hor kt-login__aside" style="background-color:#adafb3;">
                    <div class="kt-grid__item">
                        <a href="#" class="kt-login__logo">
                            @*<img style="height:50px;" src="https://www.a2aenergy.com/images/logo.png">*@
                            <img style="height:60px;" src="~/assets/images/Docplus.png" />
                        </a>
                    </div>
                    <div class="kt-grid__item kt-grid__item--fluid kt-grid kt-grid--ver">
                        <div class="kt-grid__item kt-grid__item--middle">
                            <h3 class="kt-login__title">Welcome DocPLUS</h3>
                            <p class="login-slogan">
                                Where Technology Meets Patient Care
                            </p>
                            @* <h3 class="kt-login__subtitle">Let's Elevate the Energy IQ</h3> *@
                        </div>
                    </div>
                    <div class="kt-grid__item">
                        <div class="kt-login__info">
                            <div class="kt-login__copyright">
                                &copy @DateTime.Now.Year Conveniotech Systems Pvt. Ltd.
                            </div>
                            @*<div class="kt-login__menu">
                                    <a href="#" class="kt-link">Privacy</a>
                                    <a href="#" class="kt-link">Legal</a>
                                    <a href="#" class="kt-link">Contact</a>
                                </div>*@
                        </div>
                    </div>
                </div>

                <!--begin::Aside-->
                <!--begin::Content-->
                <div class="kt-grid__item kt-grid__item--fluid  kt-grid__item--order-tablet-and-mobile-1  kt-login__wrapper login-bg" style="background-image: url('@Url.Content("~/assets/images/login_background.png")');">

                    <!--begin::Body-->
                    <div class="kt-login__body">

                        <!--begin::Signin-->
                        <div class="kt-login__form">
                            <div class="kt-login__title">
                                <h3 style="color: #fcfcff !important;">Sign In</h3>
                            </div>

                            <!--begin::Form-->
                            <form asp-controller="Login" asp-action="Index" method="post" class="kt-form">
                                <div class="form-group">
                                    <input type="text" asp-for="UserName" class="form-control" id="txtUserName" placeholder="Username" name="UserName" autocomplete="off">
                                    <span asp-validation-for="UserName" class="text-danger"></span>
                                </div>
                                <div class="form-group">
                                    <input type="password" asp-for="Password" class="form-control" id="txtPassword" placeholder="Password" name="Password" autocomplete="off">
                                    <span asp-validation-for="Password" class="text-danger"></span>
                                </div>
                                <div class="form-group">

                                    <!-- TOP ROW -->
                                    <div style="display:flex; gap:15px; align-items:flex-start; margin-top:10px;">

                                        <!-- CAPTCHA BOX -->
                                        <div style="
        border-radius:5px;
        border:1px solid black;
        width:160px;
        height:48px;
        display:flex;
        align-items:center;
        justify-content:center;
        background:#adacac;
    ">
                                            <img src="/Login/GenerateCaptcha"
                                                 id="captchaImage"
                                                 style="height:30px; display:block;" />
                                        </div>

                                        <!-- INPUT + REFRESH -->
                                        <div style="display:flex; flex-direction:column;">

                                            <!-- INPUT -->
                                            <input type="text" name="CaptchaCode"
                                                   placeholder="Enter Captcha"
                                                   class="form-control"
                                                   autocomplete="off"
                                                   style="

                   width:275px;
                   height:48px;
                   font-size:16px;
                   padding:6px 12px;
                   line-height:1.5; margin-top: 0rem !important;
               " />

                                            <!-- REFRESH -->
                                            <div style="text-align:right; margin-top:4px;">
                                                <a href="javascript:void(0);"
                                                   onclick="refreshCaptcha()"
                                                   style="color:#fff; font-size:14px; text-decoration:none;">
                                                    <i class="fas fa-sync-alt"></i> Refresh
                                                </a>
                                            </div>
                                            <!-- VALIDATION -->
                                            <span class="text-danger">
                                                @Html.ValidationMessage("CaptchaError")
                                            </span>
                                        </div>



                                    </div>
                                    <input name="__RequestVerificationToken" type="hidden" value="">
                                    <br />
                                    <span class="text-danger">@Html.ValidationMessage("IncorrectCredentials")</span>
                                    <!--begin::Action-->
                                    <div class="kt-login__actions" style="margin: 0rem 0 !important;">
                                        @*<a href="#" class="kt-link kt-login__link-forgot">
                                            Forgot Password ?
                                        </a>*@
                                        <button id="kt_login_signin_submit" style="background-color: #5867dd;border-color: #5867dd;" class="btn btn-primary btn-elevate kt-login__btn-primary">Sign In</button>
                                    </div>

                                    <!--end::Action-->
                            </form>

                            <!--end::Form-->
                        </div>
                        <!--end::Signin-->
                    </div>
                    <!--end::Body-->
                    <!--begin::Head-->
                    @*<div class="kt-login__head">
                            <span class="kt-login__signup-label">Don't have an account yet?</span>&nbsp;&nbsp;
                            <a href="#" class="kt-link kt-login__signup-link">Sign Up!</a>
                        </div>*@

                    <!--end::Head-->
                </div>
                <!--end::Content-->
            </div>
        </div>
    </div>

    <!-- end:: Page -->
    <!-- begin::Global Config(global config for global JS sciprts) -->
    <script>
        var KTAppOptions = {
            "colors": {
                "state": {
                    "brand": "#5D78FF",
                    "dark": "#282A3C",
                    "light": "#FFFFFF",
                    "primary": "#5867DD",
                    "success": "#34BFA3",
                    "info": "#36A3F7",
                    "warning": "#FFB822",
                    "danger": "#FD3995"
                },
                "base": {
                    "label": ["#C5CBE3", "#A1A8C3", "#3D4465", "#3E4466"],
                    "shape": ["#F0F3FF", "#D9DFFA", "#AFB4D4", "#646C9A"]
                }
            }
        };

        function refreshCaptcha() {
            var img = document.getElementById("captchaImage");
            img.src = '/Login/GenerateCaptcha?' + new Date().getTime();
        }

    </script>

    <!-- end::Global Config -->
    <!--begin:: Global Mandatory Vendors -->
    <script src="~/assetsnew/vendors/general/jquery/dist/jquery.min.js" asp-append-version="true" type="text/javascript"></script>
    <script src="~/assets/vendors/general/popper.js/dist/umd/popper.min.js" asp-append-version="true" type="text/javascript"></script>
    <script src="~/assetsnew/vendors/general/bootstrap-bootstrap/dist/js/bootstrap.min.js" asp-append-version="true" type="text/javascript"></script>
    <script src="~/assets/vendors/general/js-cookie/src/js.cookie.js" asp-append-version="true" type="text/javascript"></script>
    <script src="~/assets/vendors/general/moment/min/moment.min.js" asp-append-version="true" type="text/javascript"></script>
    <script src="~/assets/vendors/general/tooltip.js/dist/umd/tooltip.min.js" asp-append-version="true" type="text/javascript"></script>
    <script src="~/assets/vendors/general/perfect-scrollbar/dist/perfect-scrollbar.min.js" asp-append-version="true" type="text/javascript"></script>
    <script src="~/assets/vendors/general/sticky-js/dist/sticky.min.js" asp-append-version="true" type="text/javascript"></script>
    <script src="~/assets/vendors/general/wnumb/wNumb.js" asp-append-version="true" type="text/javascript"></script>

    <!--end:: Global Mandatory Vendors -->
    <!--begin::Global Theme Bundle(used by all pages) -->
    <script src="~/assets/js/demo1/scripts.bundle.min.js" asp-append-version="true" type="text/javascript"></script>

    <!--end::Global Theme Bundle -->
    <div class="loader" id="wait" style="display: none;">
        <span class="dot"></span>
        <span class="dot"></span>
        <span class="dot"></span>
        <span class="dot"></span>
        <span class="dot"></span>
    </div>
</body>

<!-- end::Body -->
</html>