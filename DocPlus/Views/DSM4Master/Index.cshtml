@using System.Reflection
@inject IStringLocalizerFactory LocalizerFactory

@{
    var Localizer = LocalizerFactory.Create("SharedResource", Assembly.GetExecutingAssembly().GetName().Name);
    ViewData["Title"] = @Localizer["DSM4_Master"];
}
<style>
    .modal-dialog {
        max-width: 950px !important;
    }

    #tblDSM4 th:nth-child(3),
    #tblDSM4 th:nth-child(4),
    #tblDSM4 td:nth-child(3),
    #tblDSM4 td:nth-child(4) {
        text-align: center !important;
        white-space: nowrap;
        width: 15%; /* remove extra space */
    }

    #tblDSM4 td:nth-child(4) {
        padding-right: 5px !important; /* spacing */
    }

    #tblDSM4 td:nth-child(3) {
        padding-right: 8px !important;
    }

    #tblDSM4 td:nth-child(1),
    #tblDSM4 th:nth-child(1) {
        width: 25%; /* shrink DSM/ICD code column */
        white-space: nowrap;
    }

    #tblDSM4 td:nth-child(2),
    #tblDSM4 th:nth-child(2) {
        width: auto; /* remarks takes only needed space */
    }

    #tblICD10 td:nth-child(2),
    #tblICD10 th:nth-child(2) {
        width: auto; /* remarks takes only needed space */
    }

</style>

<!-- SUBHEADER -->

<div class="kt-subheader kt-grid__item" id="kt_subheader">

    <div class="kt-subheader__main">

        <div class="kt-subheader__breadcrumbs">

            <a asp-controller="Dashboard" asp-action="Index" class="kt-subheader__breadcrumbs-home">
                <i class="flaticon2-shelter"></i>
            </a>

            <span class="kt-subheader__breadcrumbs-separator"></span>

            <a href="javascript:;" class="kt-subheader__breadcrumbs-link">
                @Localizer["Basic_Settings"]
            </a>

            <span class="kt-subheader__breadcrumbs-separator"></span>

            <a asp-controller="StatusMaster" asp-action="Index" class="kt-subheader__breadcrumbs-link">
                @Localizer["DSM4_Master"]
            </a>

        </div>
    </div>
    <!-- RIGHT SIDE → Buttons -->
    <div class="kt-subheader__toolbar d-flex">

        <button ="javascript:;" id="btnAddDSM4"
                class="btn btn-brand btn-elevate btn-icon-sm mr-2"
                onclick="DSM4.SetForAdd();" title="@Localizer["Add_DSM4"]">
            <i class="fas fa-plus-circle"></i> @Localizer["Add_DSM4"]
        </button>

        <div id="divExport">
            <button type="button"
                    class="btn btn-default btn-icon-sm"
                    onclick="DSM4Master.Export();" title="@Localizer["Export"]">
                <i class="la la-download"></i> Export
            </button>
        </div>

    </div>

</div>

<!-- MAIN GRID -->

<div class="kt-portlet kt-portlet--mobile">

    <div class="kt-portlet__body table-responsive"
         id="divIDViewDSM4"
         style="display:none;">

        <table class="table table-striped table-hover table-checkable" id="tblDSM4">

            <thead>
                <tr>
                    <th title="@Localizer["DSM4_Code"]">
                        @Localizer["DSM4_Code"]
                    </th>

                    <th title="@Localizer["Remarks"]">
                        @Localizer["Remarks"]
                    </th>

                    <th style="text-align:right;"
                        title="@Localizer["Edit"]">
                        @Localizer["Edit"]
                    </th>

                    <th style="text-align:right;"
                        title="@Localizer["Delete"]">
                        @Localizer["Delete"]
                    </th>
                </tr>
            </thead>

            <tbody></tbody>

        </table>

    </div>

</div>
<!-- Add ICD10 Modal -->
<div class="modal fade" id="AddDSM4Modal">

    <div class="modal-dialog modal-dialog-centered">

        <div class="modal-content">

            <div class="modal-header">

                <h5 class="modal-title" id="lblDSM4Title">
                    @Localizer["Add_DSM4"]
                </h5>

                <button type="button"
                        class="close"
                        data-dismiss="modal"
                        onclick="DSM4.SetForClose();"
                        title="@Localizer["Close"]">
                </button>

            </div>

            <div class="modal-body">

                <form id="frmICD10">

                    <div class="row">

                        <div class="col-md-6">
                            <div class="form-group">
                                <label>
                                    @Localizer["DSM4_Code"]
                                </label>
                                <input type="text"
                                       id="txtDSM4Code"
                                       class="form-control"
                                       maxlength="10"
                                       placeholder="@Localizer["Enter_DSM4_Code"]" autocomplete="off" />
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-group">
                                <label>
                                    @Localizer["Remarks"]
                                </label>
                                <input type="text"
                                       id="txtDSM4Remarks"
                                       class="form-control"
                                       maxlength="50"
                                       placeholder="@Localizer["Enter_Remark"]" autocomplete="off" />
                            </div>
                        </div>

                    </div>

                </form>

            </div>

            <div class="modal-footer">

                <button class="btn btn-success"
                        title="@Localizer["Save"]"
                        onclick="DSM4.AddUpdate();">
                    @Localizer["Save"]
                </button>

                <button type="button"
                        class="btn btn-warning"
                        title="@Localizer["Reset"]"
                        onclick="DSM4.ResetData();">
                    @Localizer["Reset"]
                </button>

                <button class="btn btn-danger"
                        title="@Localizer["Close"]"
                        onclick="DSM4.SetForClose();">
                    @Localizer["Close"]
                </button>

            </div>

        </div>

    </div>

</div>

<!-- Anti-forgery token -->
<form id="__AjaxAntiForgeryForm">
    @Html.AntiForgeryToken()
</form>
<!-- Hidden Field -->
<input type="hidden" id="hdnDSM4ID" value="0" />
<script id="Grid_Data_Template_tblDSM4" type="text/x-jquery-tmpl">
    <tr>

        <!-- ICD10 Code -->
        <td title="${dsM4_CODE}" style="cursor:pointer;">
            ${dsM4_CODE}
        </td>

        <!-- Remarks -->
        <td title="${dsM4_REMARKS}" style="cursor:pointer;">
            ${dsM4_REMARKS}
        </td>

        <!-- Edit -->
        <td>
            <i class="fa fa-edit text-primary action-icon"
               onclick="DSM4.Edit(${dsM4_ID})"
               title="@Localizer["Edit"]"
               style="cursor:pointer;">
            </i>
        </td>

        <!-- Delete -->
        <td>
            <i class="fa fa-trash text-danger action-icon"
               onclick="DSM4.Delete(${dsM4_ID},'${dsM4_CODE}','${dsM4_REMARKS}')"
               title="@Localizer["Delete"]"
               style="cursor:pointer;">
            </i>
        </td>

    </tr>
</script>
<script src="~/scripts/dsm4master.js"></script>