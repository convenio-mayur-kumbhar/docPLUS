@section Scripts{

<script src="~/assets/js/jquery.dataTables.min.js"></script>
<script src="~/assets/js/dataTables.bootstrap.min.js"></script>


<script>

var doctorMaster={

data:[],
table:null,

Init:function(){

this.table=$("#tblDoctor").DataTable({

pageLength:10,
ordering:true

});

},


OpenAdd:function(){

$("#DoctorModal").modal("show");

},


Save:function(){

var d={

shortcode:$("#txtShortcode").val(),
name:$("#txtName").val(),
mobile:$("#txtMobile").val(),
email:$("#txtEmail").val(),
remark:$("#txtRemark").val(),
status:$("#ddlStatus").val()

};


this.data.push(d);

this.Load();

$("#DoctorModal").modal("hide");

this.ResetForm();

},


Load:function(){

this.table.clear();

this.data.forEach(function(x,i){

doctorMaster.table.row.add([

x.shortcode,
x.name,
x.mobile,
x.email,
x.remark,
x.status,

"<i class='fa fa-edit' onclick='doctorMaster.Edit("+i+")'></i>",

"<i class='fa fa-trash text-danger' onclick='doctorMaster.Delete("+i+")'></i>"

]);

});

this.table.draw();

},


Edit:function(i){

var d=this.data[i];

$("#txtShortcode").val(d.shortcode);
$("#txtName").val(d.name);
$("#txtMobile").val(d.mobile);
$("#txtEmail").val(d.email);
$("#txtRemark").val(d.remark);
$("#ddlStatus").val(d.status);

this.data.splice(i,1);

this.OpenAdd();

},


Delete:function(i){

if(confirm("Delete Doctor?")){

this.data.splice(i,1);

this.Load();

}

},


Search:function(){

this.table.column(1).search($("#txtDoctorName").val());
this.table.column(2).search($("#txtDoctorMobile").val());

this.table.draw();

},


Reset:function(){

$("#txtDoctorName").val("");
$("#txtDoctorMobile").val("");

this.table.search("").columns().search("").draw();

},


Export:function(){

alert("Export logic here");

},


ResetForm:function(){

$("#frmDoctor")[0].reset();

}

};


$(document).ready(function(){

doctorMaster.Init();

});

</script>

}