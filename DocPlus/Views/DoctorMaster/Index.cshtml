@using System.Reflection
@inject IStringLocalizerFactory LocalizerFactory

@{
    var Localizer = LocalizerFactory.Create("SharedResource", Assembly.GetExecutingAssembly().GetName().Name);
    ViewData["Title"] = @Localizer["Doctor Master"];
}

@using (Html.BeginForm(null, null, FormMethod.Post, new { id = "__AjaxAntiForgeryForm" }))
{
    @Html.AntiForgeryToken()
}
<style>
    .modal-dialog {
        max-width: 900px !important;
    }
</style>


<!-- SUBHEADER -->

<div class="kt-subheader kt-grid__item" id="kt_subheader">

    <div class="kt-subheader__main">

        <div class="kt-subheader__breadcrumbs">

            <a asp-controller="Dashboard" asp-action="Index" class="kt-subheader__breadcrumbs-home">
                <i class="flaticon2-shelter"></i>
            </a>

            <span class="kt-subheader__breadcrumbs-separator"></span>

            <a href="javascript:;" class="kt-subheader__breadcrumbs-link">
                @Localizer["Basic Settings"]
            </a>

            <span class="kt-subheader__breadcrumbs-separator"></span>

            <a asp-controller="DoctorMaster" asp-action="Index" class="kt-subheader__breadcrumbs-link">
                @Localizer["Doctor Master"]
            </a>

        </div>
    </div>
    <!-- RIGHT SIDE → Buttons -->
    <div class="kt-subheader__toolbar d-flex">

        <a href="javascript:;" id="btnAddDoctor"
           class="btn btn-brand btn-elevate btn-icon-sm mr-2"
           onclick="doctorMaster.SetForAdd();">
            <i class="fas fa-plus-circle"></i> @Localizer["Add Doctor"]
        </a>

        <div id="divExport">
            <button type="button"
                    class="btn btn-default btn-icon-sm"
                    onclick="doctor.Export();">
                <i class="la la-download"></i> Export
            </button>
        </div>

    </div>

</div>


<!-- SEARCH FILTER -->
<div class="kt-portlet kt-portlet--mobile p-3 mb-2">

    <div class="form-group row align-items-end">

        <div class="col-md-3">
            <label>@Localizer["Doctor Name"]:<span class="text-danger"><asterisk></asterisk></span></label>
            <input type="text"
                   id="txtDoctorName"
                   class="form-control"
                   placeholder="Enter Doctor Name">
        </div>

        <div class="col-xs-12 col-md-3 col-lg-3">
            <label>@Localizer["Mobile_No"]: <span class="text-danger"><asterisk></asterisk></span></label>
            <input type="text" class="form-control" id="txtCell" readonly placeholder="Enter Mobile Number" />
        </div>
        <div class="col-md-6">
            <button type="button" class="btn btn-success"
                    onclick="doctorMaster.SetForSearch()">
                @Localizer["Search"]
            </button>
            <button type="button" class="btn btn-danger"
                    onclick="doctorMaster.ResetSearch();">
                @Localizer["Reset"]
            </button>

        </div>

    </div>

    <!-- Dynamic Search Results -->
    <div id="doctorResults" class="mt-3">
        <!-- Doctor will be rendered here -->
    </div>

</div>


<!-- GRID -->
<div class="kt-portlet kt-portlet--mobile">

    <div class="kt-portlet__body table-responsive" id="divIDViewDoctor">
        <!--begin: Datatable -->
        <table class="table table-striped table-hover table-checkable"
               id="tblDoctorMaster">

            <template>
                Doctor List
            </template>

            <thead>
                <tr>
                    <th>@Localizer["Shortcode"]</th>
                    <th>@Localizer["Name"]</th>
                    <th>@Localizer["Address"]</th>
                    <th>@Localizer["Mobile_No"]</th>
                    <th>@Localizer["Tele_No"]</th>
                    <th>@Localizer["Email"]</th>
                    <th>@Localizer["Remark"]</th>
                    <th>@Localizer["Edit"]</th>
                    <th>@Localizer["Delete"]</th>
                </tr>
            </thead>

            <tbody></tbody>
        </table>
        <script id="Grid_Data_Template_tblDoctorMaster" type="text/x-jquery-tmpl">

            
               <tr data-id="${doC_ID}">

                <td>${doC_SCODE}</td>
                <td>${doC_NAME}</td>
                <td>${doC_ADDR}</td>
                <td>${doC_MOBNO}</td>
                <td>${doC_TELENO}</td>
                <td>${doC_EMAIL}</td>
                <td>${doC_REMARKS}</td>

                <!-- Edit -->
                <td class="text-center">
                    <button type="button"
                            class="btn btn-sm btn-primary"
                           onclick="doctorMaster.SetForUpdate('${doC_ID}')">
                        Edit
                    </button>
                </td>

                <!-- Delete -->
                <td class="text-center">
                    <button type="button"
                            class="btn btn-sm btn-danger"
                           onclick="doctorMaster.Delete(${doC_ID}, '${doC_NAME}')">
                        Delete
                    </button>
                </td>

            </tr>

        </script>
    </div>

</div>


<div class="modal fade" id="DoctorModal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
        <div class="modal-content">

            <!-- HEADER -->
            <div class="modal-header">
                <h5 class="modal-title" id="DoctorModalTitle">
                    @Localizer["Doctor_Details"] <span class="text-danger">*</span>
                </h5>
                <button type="button" class="close" data-dismiss="modal" onclick="doctorMaster.SetForClose();"></button>
            </div>

            <!-- BODY -->
            <div class="modal-body">
                <form id="frmDoctor">

                    <!-- Hidden ID -->
                    <input type="hidden" id="DOC_ID" />

                    <div class="row">

                        <div class="col-md-4 form-group">
                            <label>@Localizer["Shortcode"]</label>
                            <input type="text" id="txtShortcode" class="form-control" placeholder="@Localizer["Enter Shortcode"]">
                        </div>

                        <div class="col-md-4 form-group">
                            <label>@Localizer["Name"] <span class="text-danger"><asterisk></asterisk></span></label>
                            <input type="text" class="form-control" id="txtName" placeholder="@Localizer["Enter Name"]">
                        </div>

                        <div class="col-md-4 form-group">
                            <label>@Localizer["Mobile_No"]</label>
                            <input type="text" id="txtMobileNo" class="form-control"
                                   placeholder="@Localizer["Enter Mobile No"]">
                        </div>

                    </div>

                    <div class="row">

                        <div class="col-md-4 form-group">
                            <label>@Localizer["Email"]</label>
                            <input type="text" id="txtEmail" class="form-control"
                                   placeholder="@Localizer["Enter Email"]">
                        </div>

                        <div class="col-md-4 form-group">
                            <label>@Localizer["Tele_No"]</label>
                            <input type="text" id="txtTeleNo" class="form-control"
                                   placeholder="@Localizer["Enter Telephone No"]">
                        </div>

                        <div class="col-md-4 form-group">
                            <label>@Localizer["Remarks"]</label>
                            <input type="text" id="txtRemark" class="form-control" placeholder="@Localizer["Enter Remark"]">
                        </div>

                    </div>

                    <div class="row">
                        <div class="col-md-6 form-group">
                            <label>@Localizer["Address"]</label>
                            <textarea type="text" id="txtAddress" class="form-control"
                                      placeholder="@Localizer["Enter Address"]"></textarea>
                        </div>
                    </div>

                </form>
            </div>

            <!-- FOOTER -->
            <div class="modal-footer">

                <button type="button" class="btn btn-success" onclick="doctorMaster.SaveDoctor();">
                    @Localizer["Save"]                   
                </button>

                <button type="button" class="btn btn-warning" onclick="doctorMaster.ResetForm();">                        
                         @Localizer["Reset"]
                </button>

                <button class="btn btn-danger" onclick="doctorMaster.SetForClose();">                        
                    @Localizer["Close"]
                </button>

            </div>

        </div>
    </div>
</div>
<script src="~/scripts/DoctorMaster.js"></script>

