@section Scripts {
    <script>
        var doctorMaster = {
            doctors: [],
            table: null,

            Init: function () {
                this.table = $('#tblDoctorMaster').DataTable({
                    pageLength: 10,
                    lengthMenu: [10,25,50],
                    ordering: true
                });
                this.LoadDoctors();
            },

            LoadDoctors: function () {
                this.table.clear();
                this.doctors.forEach(function(d, i){
                    doctorMaster.table.row.add([
                        d.shortcode,
                        d.name,
                        d.mobile,
                        d.email,
                        d.remark,
                        d.status,
                        "<center><i class='fa fa-edit fa-lg' onclick='doctorMaster.EditDoctor("+i+")'></i></center>",
                        "<center><i class='fa fa-trash text-danger' onclick='doctorMaster.DeleteDoctor("+i+")'></i></center>"
                    ]);
                });
                this.table.draw();
            },

            FilterDoctors: function () {
                var name = $('#txtDoctorName').val();
                var mobile = $('#txtDoctorMobile').val();
                this.table.column(1).search(name);
                this.table.column(2).search(mobile);
                this.table.draw();
            },

            OpenAddPanel: function () {
                $('#divAddForm').show();
            },
            CloseAddPanel: function () {
                $('#divAddForm').hide();
            },
            ResetForm: function () {
                $('#txtShortcode,#txtName,#txtMobile,#txtEmail,#txtRemark').val('');
                $('#ddlStatus').val('Active');
            },
            SaveDoctor: function () {
                var doctor = {
                    shortcode: $('#txtShortcode').val(),
                    name: $('#txtName').val(),
                    mobile: $('#txtMobile').val(),
                    email: $('#txtEmail').val(),
                    remark: $('#txtRemark').val(),
                    status: $('#ddlStatus').val()
                };
                if(!doctor.shortcode || !doctor.name){
                    alert("Enter required fields");
                    return;
                }
                this.doctors.push(doctor);
                this.ResetForm();
                this.CloseAddPanel();
                this.LoadDoctors();
            },
            EditDoctor: function(i){
                var d = this.doctors[i];
                $('#txtShortcode').val(d.shortcode);
                $('#txtName').val(d.name);
                $('#txtMobile').val(d.mobile);
                $('#txtEmail').val(d.email);
                $('#txtRemark').val(d.remark);
                $('#ddlStatus').val(d.status);
                this.doctors.splice(i,1);
                this.OpenAddPanel();
            },
            DeleteDoctor: function(i){
                if(confirm("Delete doctor?")){
                    this.doctors.splice(i,1);
                    this.LoadDoctors();
                }
            },
            ExportDoctors: function(){
                alert("Export functionality here");
            }
        };

        $(document).ready(function(){
            doctorMaster.Init();
        });
    </script>
} *@
